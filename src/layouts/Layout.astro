}
.newcomer-cta h2 em {
  color: var(--gold-bright);
}
.newcomer-cta p {
  color: rgba(244, 237, 224, 0.78);
  font-size: 14px;
  line-height: 1.55;
  margin-bottom: 24px;
  max-width: 34ch;
