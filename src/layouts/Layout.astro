/* ───────────────────────────── motion */
@keyframes rise {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
.rise { animation: rise .7s cubic-bezier(.2,.6,.2,1) both; }
.d-1 { animation-delay: .05s; }
.d-2 { animation-delay: .15s; }
.d-3 { animation-delay: .25s; }
.d-4 { animation-delay: .35s; }
.d-5 { animation-delay: .45s; }
.d-6 { animation-delay: .55s; }
.d-7 { animation-delay: .65s; }

@media (prefers-reduced-motion: reduce) {
  .rise, [class^="d-"] { animation: none; }
  html { scroll-behavior: auto; }
  .btn:hover { transform: none; }
}

/* ───────────────────────────── responsive breakpoints */
@media (max-width: 1060px) {
