.newcomer-cta {
  /* Magenta block, strong club-colour moment on the homepage. White text
     on plum reads at AAA contrast (>7:1). Gold accents stay legible. */
  background: var(--plum);
  color: var(--paper);
  padding: 32px 28px 28px;
  display: flex; flex-direction: column;
  position: relative;
  overflow: hidden;
