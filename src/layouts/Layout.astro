}
.newcomer-cta .btn {
  background: var(--gold);
  color: var(--ink);
  font-weight: 500;
  align-self: flex-start;
  margin-top: auto;
  position: relative; z-index: 1;
}
.newcomer-cta .btn:hover { background: var(--gold-bright); color: var(--ink); }

