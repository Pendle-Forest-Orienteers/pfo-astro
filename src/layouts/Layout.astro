  color: var(--ink-soft);
  margin-bottom: 20px;
  font-size: 15px;
  line-height: 1.55;
}
.news-body .more {
  margin-top: auto;
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--ff-mono);
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink);
  padding-bottom: 6px;
  border-bottom: 1px solid var(--ink);
