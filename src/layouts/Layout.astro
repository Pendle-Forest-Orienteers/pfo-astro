  border: 2px solid rgba(244, 237, 224, 0.08);
  border-radius: 50%;
}
.newcomer-cta .eyebrow { color: var(--gold-bright); margin-bottom: 20px; position: relative; z-index: 1; }
.newcomer-cta .eyebrow::before { background: var(--gold); }
.newcomer-cta h2 {
  font-family: var(--ff-display);
  font-weight: 400;
  font-size: clamp(24px, 2.2vw, 32px);
  line-height: 1.1;
  letter-spacing: -0.015em;
  font-variation-settings: "opsz" 48, "SOFT" 20;
  margin-bottom: 14px;
