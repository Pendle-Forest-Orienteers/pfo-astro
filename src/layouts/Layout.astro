/* ───────────────────────────── bottom split: latest + newcomers */
.bottom-split {
  max-width: var(--max-w); margin: 0 auto;
  padding: clamp(24px, 4vw, 56px) var(--pad-x) clamp(40px, 5vw, 72px);
