<!-- Netlify Identity widget, handles committee logins for the /admin CMS.
     Loaded lazily on non-admin pages so it doesn't bloat the homepage payload
     for ordinary visitors. The widget is still needed everywhere so that
     email-invite confirmation links land correctly on any page, but we defer
     the network fetch until the browser is idle. -->
<script is:inline>
  (function () {
    function loadIdentity() {
      var s = document.createElement('script');
      s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
      s.async = true;
      s.onload = function () {
        if (!window.netlifyIdentity) return;
        window.netlifyIdentity.on('init', function (user) {
          if (!user) {
            window.netlifyIdentity.on('login', function () {
              document.location.href = '/admin/';
            });
          }
        });
      };
      document.head.appendChild(s);
    }
    // Load immediately on /admin (the CMS depends on it). Elsewhere defer
    // until the browser is idle so it doesn't compete with above-the-fold
    // rendering. Also load if the URL contains an invite/recovery token.
    var pathname = window.location.pathname || '';
    var hash = window.location.hash || '';
    var isAdmin = pathname.indexOf('/admin') === 0;
    var hasAuthToken = hash.indexOf('invite_token') !== -1
                    || hash.indexOf('recovery_token') !== -1
                    || hash.indexOf('confirmation_token') !== -1;
    if (isAdmin || hasAuthToken) {
      loadIdentity();
    } else if ('requestIdleCallback' in window) {
      requestIdleCallback(loadIdentity, { timeout: 3000 });
    } else {
      setTimeout(loadIdentity, 2000);
    }
  })();
</script>

