---
import Layout from '../layouts/Layout.astro';

// Committee data — single source of truth.
//
// Each member has an `email` field used for the per-person mailto button.
// Role-based aliases (chair@, secretary@, treasurer@ etc.) are placeholders —
// replace with the committee member's real personal address when known.
//
// Setting `email` to null hides the email button for that person; they can
// still be reached via the general info@ address shown at the top of the page.
const CLUB_EMAIL = "info@pfo.org.uk";

const committee = [
  { name: "Hannah Dabinett",  roles: ["Chair", "Equipment Officer"], photo: "/images/_thumb/HD-PFO.jpg",                        email: "chair@pfo.org.uk" },
  { name: "Helen Ellis",      roles: ["Treasurer"],                  photo: "/images/contacts/_thumb/Helen_Ellis.jpg",          email: "treasurer@pfo.org.uk" },
  { name: "Andy Ellis",       roles: ["Secretary", "Event Results", "MapRun admin", "Website", "SI Coordinator"], photo: "/images/contacts/_thumb/Andy-Halifax-urban-3-2.png", email: "secretary@pfo.org.uk" },
  { name: "Cath Wilson",      roles: ["Lead Coach", "CompassSport coordinator"],   photo: null, email: "coach@pfo.org.uk" },
  { name: "Judith Wood",      roles: ["Club Event Controller", "Permissions Officer"], photo: "/images/contacts/_thumb/Judith_Wood.jpg", email: "controller@pfo.org.uk" },
  { name: "Kay Hawke",        roles: ["Events Secretary", "Welfare Officer", "Publicity", "Social Secretary"], photo: "/images/contacts/_thumb/Kay-Hawke.jpg", email: "kay.hawke@yahoo.co.uk" },
  { name: "Emma Taylor",      roles: ["Membership Secretary"],       photo: "/images/contacts/_thumb/Emma_Taylor.jpg",          email: "membership@pfo.org.uk" },
  { name: "Colin Woolford",   roles: ["Mapping Co-ordinator"],       photo: null, email: "mapping@pfo.org.uk" },
  { name: "Helen Smethurst",  roles: ["Equipment Officer"],          photo: null, email: "equipment@pfo.org.uk" },
  { name: "Daniel Allen",     roles: ["Permissions Officer"],        photo: "/images/contacts/_thumb/Danny_Allen2.jpg",         email: "permissions@pfo.org.uk" },
];

const initials = (name: string) => name.split(' ').map(p => p[0]).join('').slice(0, 2).toUpperCase();
---
<Layout
  title="Contacts — Pendle Forest Orienteers"
  description="Get in touch with the PFO committee — chair, secretary, treasurer, events, membership and more."
>

<main id="main">

  <section class="page-hero">
    <div class="page-hero-wrap">
      <p class="eyebrow rise d-1">Contacts</p>
      <h1 class="rise d-2">Who does what at PFO.</h1>
      <p class="page-lede rise d-3">PFO is run entirely by volunteers — every committee member below is doing this in their spare time. Pick the right person for your question and they'll get back to you when they can.</p>
    </div>
  </section>

  <section class="contact-club">
    <div class="contact-club-wrap">
      <p class="eyebrow">Get in touch</p>
      <h2>Not sure who to ask?</h2>
      <p>Email the club at <a class="club-email" href={`mailto:${CLUB_EMAIL}`}>{CLUB_EMAIL}</a> and the right person on the committee will pick it up.</p>
      <ul class="club-channels">
        <li>
          <a href={`mailto:${CLUB_EMAIL}`} class="club-channel">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="1.5"></rect>
              <polyline points="3,7 12,13 21,7"></polyline>
            </svg>
            <span><strong>Email the club</strong><br>{CLUB_EMAIL}</span>
          </a>
        </li>
        <li>
          <a href="https://www.facebook.com/pendleorienteer/" rel="noopener" class="club-channel">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 22v-8h3l1-4h-4V7.5c0-1.2.4-2 2-2h2V2h-3c-2.8 0-4.5 1.6-4.5 4.5V10H6v4h3.5v8H13z"></path></svg>
            <span><strong>Facebook</strong><br>@pendleorienteer</span>
          </a>
        </li>
        <li>
          <a href="https://www.instagram.com/pendleforestorienteerers/" rel="noopener" class="club-channel">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="4"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
            </svg>
            <span><strong>Instagram</strong><br>@pendleforestorienteerers</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="contacts-section">
    <div class="contacts-wrap">
      <ul class="contacts-grid">
        {committee.map(person => (
          <li class="contact-card">
            <div class="contact-photo">
              {person.photo ? (
                <img src={person.photo} alt="" loading="lazy">
              ) : (
                <span class="contact-initials" aria-hidden="true">{initials(person.name)}</span>
              )}
            </div>
            <div class="contact-body">
              <h2>{person.name}</h2>
              <ul class="contact-roles">
                {person.roles.map(role => <li>{role}</li>)}
              </ul>
              {person.email && (
                <a class="contact-button" href={`mailto:${person.email}`}>
                  Email {person.name.split(' ')[0]} →
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="info-block alt">
    <div class="info-wrap">
      <p class="eyebrow">Tips</p>
      <h2>Picking the right person.</h2>
      <p>For event-day enquiries close to a fixture, the listed event organiser on the relevant <a href="/events">event page</a> is your fastest route.</p>
      <p>Membership-specific questions go to <strong>Emma Taylor</strong>. Press, photography, or social-media requests go to <strong>Kay Hawke</strong>. Anything else, the Secretary <strong>Andy Ellis</strong> or the general club inbox above will reach the right person.</p>
    </div>
  </section>

</main>

</Layout>

<style>
  .page-hero {
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    padding: clamp(40px, 5vw, 80px) var(--pad-x) clamp(40px, 4vw, 64px);
  }
  .page-hero-wrap { max-width: var(--max-w); margin: 0 auto; }
  .page-hero .eyebrow { color: var(--gold-muted); margin-bottom: 18px; }
  .page-hero .eyebrow::before { background: var(--plum); }
  .page-hero h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    margin: 0 0 20px 0;
    color: var(--ink);
    max-width: 22ch;
  }
  .page-lede {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0;
  }

  /* Contact the club — sits between the page hero and the committee grid */
  .contact-club {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    padding: clamp(32px, 4vw, 56px) var(--pad-x);
  }
  .contact-club-wrap {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .contact-club .eyebrow {
    color: var(--gold-muted);
    margin-bottom: 14px;
  }
  .contact-club .eyebrow::before { background: var(--plum); }
  .contact-club h2 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 48, "SOFT" 20;
    margin: 0 0 12px 0;
    color: var(--ink);
  }
  .contact-club > .contact-club-wrap > p {
    font-size: 16px;
    color: var(--ink-soft);
    margin: 0 0 24px 0;
    max-width: 60ch;
  }
  .contact-club .club-email {
    color: var(--navy);
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
    font-weight: 500;
  }
  .contact-club .club-email:hover { color: var(--plum); }

  .club-channels {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 12px;
  }
  .club-channel {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: var(--paper-2);
    color: var(--ink);
    border: 1px solid var(--rule);
    transition: background .18s ease, border-color .18s ease, transform .18s ease;
  }
  .club-channel:hover {
    background: var(--gold);
    border-color: var(--gold);
    transform: translateY(-2px);
    color: var(--ink);
  }
  .club-channel svg { width: 22px; height: 22px; flex: 0 0 22px; color: var(--navy); }
  .club-channel:hover svg { color: var(--ink); }
  .club-channel strong { font-weight: 500; display: block; font-size: 14px; }
  .club-channel span { font-family: var(--ff-mono); font-size: 12px; line-height: 1.4; color: var(--ink-soft); }
  .club-channel:hover span { color: var(--ink); }

  .contacts-section { padding: clamp(40px, 5vw, 64px) var(--pad-x); }
  .contacts-wrap { max-width: var(--max-w); margin: 0 auto; }

  .contacts-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px;
  }
  .contact-card {
    background: var(--paper);
    border: 1px solid var(--rule);
    display: flex; flex-direction: column;
    transition: transform .22s ease, box-shadow .22s ease;
  }
  .contact-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -20px rgba(27, 59, 98, 0.4);
    border-color: var(--rule-2);
  }
  .contact-photo {
    aspect-ratio: 1 / 1;
    background: var(--paper-2);
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
    display: grid; place-items: center;
  }
  .contact-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .contact-initials {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: 56px;
    color: var(--gold-muted);
    font-variation-settings: "opsz" 144, "SOFT" 20;
    letter-spacing: -0.02em;
  }
  .contact-body {
    padding: 18px 20px 20px;
    display: flex; flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }
  .contact-body h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: 21px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 36, "SOFT" 20;
    margin: 0;
    color: var(--ink);
  }
  .contact-roles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 8px;
  }
  .contact-roles li {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-muted);
    padding: 3px 8px;
    background: var(--paper-2);
    border: 1px solid var(--rule);
  }
  .contact-button {
    margin-top: auto;
    align-self: flex-start;
    font-family: var(--ff-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    transition: color .18s, border-color .18s;
  }
  .contact-button:hover { color: var(--plum); border-color: var(--plum); }

  .info-block { padding: clamp(48px, 5vw, 80px) var(--pad-x); }
  .info-block.alt { background: var(--paper-2); }
  .info-wrap { max-width: var(--max-w); margin: 0 auto; }
  .info-block .eyebrow { color: var(--gold-muted); margin-bottom: 14px; }
  .info-block .eyebrow::before { background: var(--plum); }
  .info-block h2 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 48, "SOFT" 20;
    color: var(--ink);
    margin: 0 0 18px 0;
  }
  .info-block p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 70ch;
    margin: 0 0 14px 0;
  }
  .info-block strong { color: var(--ink); font-weight: 500; }
  .info-block a { color: var(--navy); text-decoration: underline; text-decoration-color: var(--gold); text-underline-offset: 3px; }
  .info-block a:hover { color: var(--plum); }
</style>
