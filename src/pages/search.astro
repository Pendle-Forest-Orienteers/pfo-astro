---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---
<Layout
  title="Search — Pendle Forest Orienteers"
  description="Search PFO events, news, maps and information pages."
  noindex={true}
>

<Fragment slot="head">
  <!-- Pagefind UI assets. The /pagefind/ directory is generated AFTER
       `astro build` runs (by the postbuild `pagefind --site dist` step), so
       these 404 in dev mode — that's expected. They resolve correctly once
       the site is built and previewed/deployed.
       `is:inline` keeps the script out of Vite's bundler so it isn't
       resolved at build time. -->
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css">
  <!-- Preload the underlying Pagefind library so the browser fetches it
       in parallel with the page render. By the time the user types their
       first character the engine has been instantiated, so the first
       search returns near-instantly. -->
  <link rel="preload" href="/pagefind/pagefind.js" as="script">
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
</Fragment>

<main id="main">

  <PageHero
    page="search"
    eyebrow="Search"
    heading="Find what you're looking for."
    lede="Search across all events, news, maps and information pages on the PFO site. Try a venue name, event format, or anything you remember."
  />

  <section class="search-section">
    <div class="search-wrap">
      <!-- Pagefind injects an input + live results into this container -->
      <div id="search"></div>

      <noscript>
        <p class="search-help">
          On-site search needs JavaScript. Use the quick links below, or open the site map at the foot of any page.
        </p>
      </noscript>

      <div class="quick-links">
        <p class="eyebrow">Or jump straight to</p>
        <ul>
          <li><a href="/events">Events calendar</a></li>
          <li><a href="/events#past">Past results</a></li>
          <li><a href="/maps">Map library</a></li>
          <li><a href="/news">News</a></li>
          <li><a href="/newcomers">Newcomers' guide</a></li>
          <li><a href="/membership">Membership</a></li>
          <li><a href="/contacts">Committee contacts</a></li>
          <li><a href="/information">Information hub</a></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Pagefind UI is an IIFE bundle that exposes a global `PagefindUI`
       constructor. `is:inline` keeps Astro/Vite from rewriting the script. -->
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      if (typeof window.PagefindUI === 'function') {
        new window.PagefindUI({
          element: '#search',
          showImages: false,
          showSubResults: true,
          resetStyles: false,
          debounceTimeoutMs: 400,
          placeholder: 'Try a venue name, event format, or year…'
        });
      } else {
        var el = document.getElementById('search');
        if (el) {
          el.innerHTML =
            '<p class="search-help">Search will be available once the site is built. ' +
            'For now, use the quick links below.</p>';
        }
      }
    });
  </script>

</main>

</Layout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .page-hero {
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    padding: clamp(40px, 5vw, 80px) var(--pad-x) clamp(40px, 4vw, 64px);
  }
  .page-hero-wrap { max-width: var(--max-w); margin: 0 auto; }
  .page-hero .eyebrow { color: var(--gold-muted); margin-bottom: 18px; }
  .page-hero .eyebrow::before { background: var(--plum); }
  .page-hero h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    margin: 0 0 20px 0;
    color: var(--ink);
  }
  .page-lede {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0;
  }

  .search-section { padding: clamp(40px, 5vw, 64px) var(--pad-x); }
  .search-wrap { max-width: 720px; margin: 0 auto; }

  /* ── Pagefind UI overrides — keep it visually consistent with the rest of the site ── */
  #search {
    /* Pagefind reads CSS custom properties for colours; map ours onto theirs. */
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--ink);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--paper);
    --pagefind-ui-border: var(--rule-2);
    --pagefind-ui-tag: var(--paper-2);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-image-border-radius: 0;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--ff-body);

    margin-bottom: 14px;
  }
  /* Tighten the search input styling. Left padding leaves room for
     Pagefind's magnifying-glass icon; right padding leaves room for the
     "Clear" button when there's a query. */
  #search :global(.pagefind-ui__search-input) {
    padding: 14px 56px 14px 52px;
    font-size: 18px;
    background: var(--paper);
  }
  /* Slight nudge so the magnifying-glass icon sits cleanly inside the field */
  #search :global(.pagefind-ui__search-clear) { right: 14px; }
  #search :global(.pagefind-ui__search-input:focus) {
    outline: 2px solid var(--gold);
    outline-offset: -2px;
    border-color: var(--ink);
  }
  #search :global(.pagefind-ui__result) {
    border-bottom: 1px solid var(--rule);
    padding: 16px 0;
  }
  #search :global(.pagefind-ui__result-title) {
    font-family: var(--ff-display);
    font-weight: 500;
    color: var(--navy);
  }
  #search :global(.pagefind-ui__result-title a:hover) { color: var(--plum); }

  .search-help {
    font-size: 13px;
    color: var(--ink-mute);
    margin: 0 0 40px 0;
  }

  .quick-links { margin-top: 40px; padding-top: 28px; border-top: 1px solid var(--rule); }
  .quick-links .eyebrow { color: var(--gold-muted); margin-bottom: 14px; }
  .quick-links .eyebrow::before { background: var(--plum); }
  .quick-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 8px 24px;
  }
  .quick-links a {
    display: block;
    padding: 6px 0;
    font-size: 15px;
    color: var(--ink);
    border-bottom: 1px solid transparent;
    transition: color .18s, border-color .18s;
  }
  .quick-links a:hover { color: var(--plum); border-bottom-color: var(--plum); }
</style>
