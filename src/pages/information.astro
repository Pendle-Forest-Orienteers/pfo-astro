---
import Layout from '../layouts/Layout.astro';

// Information hub — links to all the policy / admin / "boring but important" pages.
// Sub-pages live at /information/<slug> as static .astro pages.
const sections = [
  {
    label: "About the club",
    items: [
      { title: "About PFO", desc: "What we do, where we cover, who runs it.", href: "/about" },
      { title: "Membership", desc: "How to join, current fees, what you get.", href: "/membership" },
      { title: "Contact the committee", desc: "Who to ask for what.", href: "/contacts" },
    ]
  },
  {
    label: "Events & participation",
    items: [
      { title: "Upcoming events", desc: "All fixtures plus past results.", href: "/events" },
      { title: "Newcomers", desc: "Never tried orienteering? Start here.", href: "/newcomers" },
      { title: "Training", desc: "Coaching and skills sessions for members.", href: "/training" },
      { title: "Anytime orienteering", desc: "Permanent courses and MapRun loops.", href: "/information/anytime-orienteering" },
      { title: "Map library", desc: "Every venue we currently use.", href: "/maps" },
    ]
  },
  {
    label: "Policies & governance",
    items: [
      { title: "PFO Constitution", desc: "How the club is structured.", href: "/information/constitution" },
      { title: "Safeguarding policy", desc: "Keeping juniors and vulnerable adults safe.", href: "/information/safeguarding" },
      { title: "Privacy statement", desc: "How we handle your personal data.", href: "/information/privacy" },
      { title: "Insurance", desc: "British Orienteering insurance and what it covers.", href: "/information/insurance" },
      { title: "Health & safety", desc: "Risk assessments, accident forms, junior medical forms.", href: "/information/health-and-safety" },
      { title: "Event cancellation policy", desc: "What happens if an event has to be called off.", href: "/information/event-cancellation-refund-policy" },
    ]
  },
  {
    label: "Members' resources",
    items: [
      { title: "Newsletter archive", desc: "Past PFO newsletters.", href: "/information/newsletter" },
      { title: "Individual & club rankings", desc: "BO ranking points and club competitions.", href: "/information/rankings" },
      { title: "PFO trophy cabinet", desc: "Club awards and what they mean.", href: "/information/trophy-cabinet" },
      { title: "Expense claim form", desc: "For event organisers and committee members.", href: "/information/expense-claim-form" },
    ]
  },
];
---
<Layout
  title="Information — Pendle Forest Orienteers"
  description="Club policies, governance, member resources, safeguarding, privacy and more."
>

<main id="main">

  <section class="page-hero">
    <div class="page-hero-wrap">
      <p class="eyebrow rise d-1">Information</p>
      <h1 class="rise d-2">Everything else.</h1>
      <p class="page-lede rise d-3">Constitution, policies, safeguarding, insurance, member resources and other useful odds and ends. If you're looking for something specific and can't find it here, the <a href="/contacts">committee</a> can usually point you in the right direction.</p>
    </div>
  </section>

  <section class="info-hub">
    <div class="info-hub-wrap">
      {sections.map(section => (
        <div class="hub-section">
          <p class="eyebrow">{section.label}</p>
          <ul class="hub-grid">
            {section.items.map(item => (
              <li>
                <a class="hub-card" href={item.href}>
                  <h2>{item.title}</h2>
                  <p>{item.desc}</p>
                  <span class="hub-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

</main>

</Layout>

<style>
  .page-hero {
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    padding: clamp(40px, 5vw, 80px) var(--pad-x) clamp(40px, 4vw, 64px);
  }
  .page-hero-wrap { max-width: var(--max-w); margin: 0 auto; }
  .page-hero .eyebrow { color: var(--gold-muted); margin-bottom: 18px; }
  .page-hero .eyebrow::before { background: var(--plum); }
  .page-hero h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    margin: 0 0 20px 0;
    color: var(--ink);
  }
  .page-lede {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0;
  }
  .page-lede a { color: var(--navy); text-decoration: underline; text-decoration-color: var(--gold); text-underline-offset: 3px; }
  .page-lede a:hover { color: var(--plum); }

  .info-hub { padding: clamp(40px, 5vw, 64px) var(--pad-x); }
  .info-hub-wrap { max-width: var(--max-w); margin: 0 auto; }

  .hub-section { margin-bottom: 56px; }
  .hub-section:last-child { margin-bottom: 0; }
  .hub-section .eyebrow {
    color: var(--gold-muted);
    margin-bottom: 18px;
  }
  .hub-section .eyebrow::before { background: var(--plum); }

  .hub-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
  }
  .hub-card {
    display: block;
    position: relative;
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 20px 24px 22px;
    color: var(--ink);
    transition: background .18s ease, border-color .18s ease, transform .18s ease;
    height: 100%;
  }
  .hub-card:hover {
    background: var(--paper-2);
    border-color: var(--rule-2);
    transform: translateY(-2px);
  }
  .hub-card h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 36, "SOFT" 20;
    color: var(--ink);
    margin: 0 0 6px 0;
  }
  .hub-card:hover h2 { color: var(--navy); }
  .hub-card p {
    font-size: 14px;
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0;
  }
  .hub-arrow {
    position: absolute;
    top: 20px; right: 24px;
    font-family: var(--ff-mono);
    font-size: 14px;
    color: var(--ink-mute);
    transition: color .18s, transform .18s;
  }
  .hub-card:hover .hub-arrow { color: var(--gold-muted); transform: translateX(4px); }
</style>
