---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// ─────── British Orienteering news, fetched at build time
// Runs every time Netlify rebuilds (every git push and every nightly cron
// trigger). If the live fetch fails for any reason, falls back to the
// hardcoded list below so the section never renders empty.
//
// To keep the headlines fresh without committee action, set up a scheduled
// build trigger in Netlify:
//   1. Site settings → Build & deploy → Build hooks → "Add build hook"
//   2. Copy the URL it generates
//   3. In a free service like https://cron-job.org, schedule a daily POST
//      to that URL, anything from once a day to once a week is fine.
type BoNewsItem = { title: string; url: string; date: Date };

const fallbackBoNews: BoNewsItem[] = [
  { title: "British Orienteering announces date for Annual General Meeting 2026",
    url: "https://www.britishorienteering.org.uk/news_archive/6783/british_orienteering_announces_date_for_annual_general_meeting_2026",
    date: new Date("2026-04-14") },
  { title: "British Middle Championships 2026, Results",
    url: "https://www.britishorienteering.org.uk/news_archive/6775/british_middle_championships_2026_results",
    date: new Date("2026-04-07") },
  { title: "JEC 2026: GB Team Announcement",
    url: "https://www.britishorienteering.org.uk/news_archive/6778/jec_2026_gb_team_announcement",
    date: new Date("2026-03-28") },
  { title: "EYOC 2026: GB Team Announcement",
    url: "https://www.britishorienteering.org.uk/news_archive/6777/eyoc_2026_gb_team_announcement",
    date: new Date("2026-03-22") },
];

// Decode the most common HTML entities a feed (or scraped page) might
// emit so that titles like "Howden's Webinar" don't render as
// "Howden&#x27;s Webinar" on the homepage. Handles named entities, plus
// numeric (&#39;) and hex (&#x27;) character references.
function decodeHtmlEntities(s: string): string {
  return s
    .replace(/&amp;/g, '&')
    .replace(/&apos;/g, "'")
    .replace(/&quot;/g, '"')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&nbsp;/g, ' ')
    .replace(/&#x([0-9a-fA-F]+);/g, (_, hex) => String.fromCodePoint(parseInt(hex, 16)))
    .replace(/&#(\d+);/g, (_, dec) => String.fromCodePoint(parseInt(dec, 10)));
}

function parseRssFeed(xml: string): BoNewsItem[] {
  const out: BoNewsItem[] = [];
  for (const m of xml.matchAll(/<item\b[\s\S]*?<\/item>/g)) {
    const block = m[0];
    const titleMatch = block.match(/<title>(?:<!\[CDATA\[)?([\s\S]*?)(?:\]\]>)?<\/title>/);
    const linkMatch  = block.match(/<link>(?:<!\[CDATA\[)?([\s\S]*?)(?:\]\]>)?<\/link>/);
    const dateMatch  = block.match(/<pubDate>([^<]+)<\/pubDate>/);
    if (titleMatch && linkMatch && dateMatch) {
      const date = new Date(dateMatch[1]);
      if (!Number.isNaN(date.getTime())) {
        out.push({
          title: decodeHtmlEntities(titleMatch[1].trim()),
          // Also decode the URL — some feeds entity-encode the slashes
          // (`&#x2f;`) which the browser then can't parse as a URL.
          url: decodeHtmlEntities(linkMatch[1].trim()),
          date,
        });
      }
    }
  }
  return out;
}

function scrapeBoNewsArchive(html: string): BoNewsItem[] {
  // BO's WordPress news archive renders a list of /news_archive/<id>/<slug>
  // links. Extract the first few unique entries.
  const out: BoNewsItem[] = [];
  const seen = new Set<string>();
  const linkRe = /href="(https?:\/\/(?:www\.)?britishorienteering\.org\.uk\/news_archive\/\d+\/[^"#]+)"[^>]*>([^<]+)</g;
  for (const m of html.matchAll(linkRe)) {
    const url = decodeHtmlEntities(m[1]);
    const title = decodeHtmlEntities(m[2].trim());
    if (seen.has(url) || !title || title.length < 8) continue;
    seen.add(url);
    out.push({ title, url, date: new Date() });
    if (out.length >= 4) break;
  }
  return out;
}

async function fetchBoNews(): Promise<BoNewsItem[]> {
  const rssCandidates = [
    // British Orienteering's actual RSS feed, discovered via the
    // <link rel="alternate" type="application/rss+xml"> on /news_archive.
    'https://www.britishorienteering.org.uk/newsrss.php',
    // Fallbacks just in case the path ever changes
    'https://www.britishorienteering.org.uk/feed/',
    'https://www.britishorienteering.org.uk/news/feed/',
    'https://www.britishorienteering.org.uk/?feed=rss2',
  ];
  for (const url of rssCandidates) {
    try {
      const res = await fetch(url, { signal: AbortSignal.timeout(6000) });
      if (!res.ok) continue;
      const items = parseRssFeed(await res.text());
      if (items.length > 0) return items.slice(0, 4);
    } catch { /* try next */ }
  }
  // RSS unavailable, try scraping the news archive page
  try {
    const res = await fetch('https://www.britishorienteering.org.uk/news_archive',
                            { signal: AbortSignal.timeout(6000) });
    if (res.ok) {
      const items = scrapeBoNewsArchive(await res.text());
      if (items.length > 0) return items;
    }
  } catch { /* fall through */ }
  return fallbackBoNews;
}

// Extra belt-and-braces, fetchBoNews already returns the static fallback on
// error, but if anything truly catastrophic happens (e.g. JSON parse blowup
// in a future change) we want the build to keep going rather than fail the
// deploy. The template hides the BO News block when this is empty.
let boNews: BoNewsItem[] = [];
try {
  boNews = (await fetchBoNews()).slice(0, 4);
} catch (err) {
  console.warn('[index] BO news fetch failed at the top level:', err);
  boNews = [];
}

const fmtBoDate = (d: Date) => new Intl.DateTimeFormat('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric'
}).format(d);

// ─────── Data: upcoming events from the content collection
import { isEventUpcoming, isEventPast } from '../lib/event-state';
const now = new Date();
const startOfToday = new Date();
startOfToday.setHours(0, 0, 0, 0);
const allEvents = await getCollection('events');

// Events stay under "Upcoming" until their start time has passed (or 8pm
// the same day if there's no start time set).
const upcoming = allEvents
  .filter(e => isEventUpcoming(e.data, now) && !e.data.cancelled && !e.data.hidden)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const nextEvent = upcoming[0];
const alsoComingUp = upcoming.slice(1, 5);

// ─────── Announcements, banners for the homepage. We pick the single
// most-severe currently-valid announcement to display.
const allAnnouncements = await getCollection('announcements');
const activeAnnouncements = allAnnouncements
  .filter(a => a.data.published
            && a.data.validFrom <= now
            && a.data.validUntil >= now)
  .sort((a, b) => {
    const order = { urgent: 0, warning: 1, info: 2 };
    return order[a.data.severity] - order[b.data.severity];
  });
const activeAnnouncement = activeAnnouncements[0];

// ─────── Latest results, most recent past event in the last 10 days that
// has at least one results file or a post-event report. Shown on the
// homepage so people landing the morning after an event can find their
// splits — or read the organiser's writeup — without hunting.
const tenDaysAgo = new Date(now.getTime() - 10 * 24 * 60 * 60 * 1000);
function hasReportText(e: { data: { report?: string } }) {
  return typeof e.data.report === 'string' && e.data.report.trim().length > 0;
}
const latestResultEvent = allEvents
  .filter(e => isEventPast(e.data, now)
            && e.data.date >= tenDaysAgo
            && !e.data.hidden
            && ((e.data.results && e.data.results.length > 0) || hasReportText(e)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

// ─────── Data: news article to feature on the homepage. Prefer
// anything with `featured: true` (most recent featured wins if there
// are several); else fall back to the most recent published article.
const allNews = (await getCollection('news'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestNews =
  allNews.find(n => n.data.featured) || allNews[0];

// ─────── Date formatters (UK English, no comma after weekday)
const fmtFeaturedDate = (d) => new Intl.DateTimeFormat('en-GB', {
  weekday: 'short', day: 'numeric', month: 'long'
}).format(d).replace(',', '');

const fmtCardDate = (d) => new Intl.DateTimeFormat('en-GB', {
  weekday: 'short', day: 'numeric', month: 'short'
}).format(d).replace(',', '');

const fmtNewsCaption = (d) => new Intl.DateTimeFormat('en-GB', {
  month: 'short', year: 'numeric'
}).format(d);

const capitalize = (s) => s.charAt(0).toUpperCase() + s.slice(1);

// ─────── Schema.org SportsOrganization JSON-LD for the homepage.
// This is what Google uses to build the club's Knowledge Panel and to
// verify the club's social-media profiles (sameAs). The PostalAddress and
// areaServed list lift visibility for queries like "orienteering Burnley"
// or "orienteering club East Lancashire".
const siteUrl = Astro.site ?? new URL("https://pfo.org.uk");
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsOrganization",
  "@id": siteUrl.toString() + "#organization",
  name: "Pendle Forest Orienteers",
  alternateName: "PFO",
  url: siteUrl.toString(),
  logo: new URL("/assets/logo.svg", siteUrl).toString(),
  image: new URL("/assets/og-default.jpg", siteUrl).toString(),
  sport: "Orienteering",
  description: "A small orienteering club covering the moors, woodland and mill towns of East Lancashire, 12–15 events a year, newcomers always welcome.",
  address: {
    "@type": "PostalAddress",
    addressRegion: "Lancashire",
    addressCountry: "GB",
  },
  areaServed: [
    { "@type": "Place", name: "Burnley" },
    { "@type": "Place", name: "Pendle" },
    { "@type": "Place", name: "Rossendale" },
    { "@type": "Place", name: "Accrington" },
    { "@type": "Place", name: "Blackburn" },
    { "@type": "Place", name: "East Lancashire" },
  ],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    url: new URL("/contacts", siteUrl).toString(),
    availableLanguage: "English",
  },
  memberOf: {
    "@type": "SportsOrganization",
    name: "British Orienteering",
    url: "https://www.britishorienteering.org.uk/",
  },
  sameAs: [
    "https://www.facebook.com/pendleorienteer/",
    "https://www.instagram.com/pendleforestorienteerers/",
  ],
};
---
<Layout
  title="Pendle Forest Orienteers, orienteering across East Lancashire"
  description="A small orienteering club covering the moors, woodland and mill towns of East Lancashire. 12–15 events a year. Newcomers always welcome."
>

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)}></script>
</Fragment>

<main id="main">

  <!-- ─────────────────────────── ANNOUNCEMENT BANNER (only if active) -->
  {activeAnnouncement && (
    <aside class={`announcement announcement-${activeAnnouncement.data.severity}`} role="status">
      <div class="announcement-wrap">
        <span class="announcement-tag" aria-hidden="true">
          {activeAnnouncement.data.severity === 'urgent' ? '⚠️' :
           activeAnnouncement.data.severity === 'warning' ? '!' : 'i'}
        </span>
        <p class="announcement-msg">{activeAnnouncement.data.message}</p>
        {activeAnnouncement.data.link && (
          <a class="announcement-link" href={activeAnnouncement.data.link} rel="noopener">
            {activeAnnouncement.data.linkLabel ?? 'Read more'} →
          </a>
        )}
      </div>
    </aside>
  )}

  <!-- ─────────────────────────── HERO -->
  <section class="hero">
    <div class="hero-backdrop" aria-hidden="true">
      <img src="/assets/photos/training-moorland.jpg" alt="" loading="eager" fetchpriority="high">
    </div>
    <!-- faint topographic contour background, layered on top of the scrim -->
    <svg class="contour-bg" viewBox="0 0 1200 700" preserveAspectRatio="none" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1">
      <path d="M-50 140 C 180 80, 360 200, 540 150 S 900 80, 1250 170"/>
      <path d="M-50 220 C 220 170, 440 280, 660 230 S 1000 170, 1250 260"/>
      <path d="M-50 320 C 240 270, 460 380, 680 330 S 980 240, 1250 350"/>
      <path d="M-50 420 C 200 380, 420 480, 640 430 S 960 350, 1250 440"/>
      <path d="M-50 520 C 260 470, 480 580, 700 530 S 980 450, 1250 540"/>
      <path d="M-50 620 C 220 570, 440 680, 660 620 S 1000 540, 1250 630"/>
    </svg>

  <div class="hero-wrap">

    <div class="hero-intro">
      <p class="eyebrow rise d-2">East Lancashire · a British Orienteering club</p>
      <h1 class="rise d-3">Orienteering across the moors, woodland and mill towns of <em>East Lancashire</em>.</h1>
      <p class="lede rise d-4">A small club running twelve to fifteen events a year, midweek street-Os, weekend regionals on the fells, and training for members. Turn up, pick a course, and navigate your way round at your own pace. <a class="lede-link" href="/membership">Join us →</a></p>
      <div class="hero-cta rise d-5">
        <a class="btn btn-primary" href="/events">All upcoming events <span class="arrow">→</span></a>
      </div>
      <dl class="hero-stats rise d-6">
        <div><dt>Mapped areas</dt><dd>30+</dd></div>
        <div><dt>Covering</dt><dd>Burnley → Blackburn</dd></div>
      </dl>
    </div>

    <!-- Right-hand column of the hero, compact Next Event + Latest
         Results cards stacked. Sits ABOVE THE FOLD next to the headline
         so the two pieces of "what's happening now" information are
         visible immediately on landing. -->
    {(nextEvent || latestResultEvent) && (
      <aside class="hero-side rise d-5" aria-label="What's happening">

        {nextEvent && (
          <article class="next-event">
            <p class="eyebrow"><a href="/events">Next event</a></p>
            <p class="event-when">
              <time datetime={nextEvent.data.date.toISOString()}>{fmtFeaturedDate(nextEvent.data.date)}</time>
              {nextEvent.data.startTime && <> · <span>{nextEvent.data.startTime}</span></>}
            </p>
            <h2><a href={`/events/${nextEvent.id}`}>{nextEvent.data.title}</a></h2>
            <p class="event-where">
              {nextEvent.data.location || nextEvent.data.summary}
            </p>
            {nextEvent.data.entryFee && (
              <p class="event-terms">
                <span>{nextEvent.data.entryFee.split(/[(.]/)[0].trim()}</span>
              </p>
            )}
            {nextEvent.data.siEntriesUrl ? (
              <a class="btn btn-primary" href={nextEvent.data.siEntriesUrl} rel="noopener">Enter via SI Entries <span class="arrow">→</span></a>
            ) : (
              <a class="btn btn-primary" href={`/events/${nextEvent.id}`}>Event details <span class="arrow">→</span></a>
            )}
          </article>
        )}

        {latestResultEvent && (
          <article class="hero-latest">
            <p class="eyebrow"><a href="/events#past">Latest results</a></p>
            <p class="hero-latest-when">
              <time datetime={latestResultEvent.data.date.toISOString()}>{fmtCardDate(latestResultEvent.data.date)}</time>
              {latestResultEvent.data.location && <> · <span>{latestResultEvent.data.location}</span></>}
            </p>
            <h2><a href={`/events/${latestResultEvent.id}`}>{latestResultEvent.data.title}</a></h2>
            <ul class="hero-latest-files">
              {(latestResultEvent.data.results ?? []).filter(r => !r.hidden).slice(0, 2).map(file => (
                <li>
                  <a href={file.url} rel="noopener">
                    <span class="hero-latest-tag">{file.type === 'pdf' ? 'PDF' : file.type === 'xlsx' ? 'Excel' : file.type === 'csv' ? 'CSV' : 'View'}</span>
                    <span class="hero-latest-label">{file.label}</span>
                  </a>
                </li>
              ))}
              {hasReportText(latestResultEvent) && (
                <li>
                  <a href={`/events/${latestResultEvent.id}/report`}>
                    <span class="hero-latest-tag">Report</span>
                    <span class="hero-latest-label">Event report</span>
                  </a>
                </li>
              )}
            </ul>
            <a class="hero-latest-link" href={`/events/${latestResultEvent.id}`}>All results →</a>
          </article>
        )}

      </aside>
    )}

  </div>

  </section><!-- /hero -->

  <!-- ─────────────────────────── UPCOMING -->
  <section class="upcoming">
    <div class="sec-head">
      <p class="eyebrow">Also coming up</p>
      <a class="sec-link" href="/events">Full calendar →</a>
    </div>
    <ul class="event-row">
      {alsoComingUp.map(event => (
        <li>
          <a class="ev-card" href={`/events/${event.id}`}>
            <span class="arrow-mono">→</span>
            <time datetime={event.data.date.toISOString()}>{fmtCardDate(event.data.date)}</time>
            <h3>{event.data.title}</h3>
            <p class="ev-sub">{event.data.summary}</p>
            <span class={`level level-${event.data.level}`}>{capitalize(event.data.level)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>


  <!-- ─────────────────────────── TAKE PART ANYTIME
       Three routes for people who can't make a formal event: the parent
       Anytime Orienteering guide, our seven Permanent Orienteering Courses,
       and MapRun virtual courses on the phone app. -->
  <section class="anytime-strip" aria-labelledby="anytime-heading">
    <div class="anytime-wrap">
      <div class="anytime-intro">
        <p class="eyebrow">Take part anytime</p>
        <h2 id="anytime-heading">Can't make a Saturday? Try these.</h2>
        <p>You don't need an event in the diary to go orienteering. PFO maintains permanent courses in seven local parks, plus virtual courses on the MapRun app, pick something that suits the day.</p>
      </div>
      <ul class="anytime-cards">
        <li>
          <a class="anytime-card" href="/information/anytime-orienteering">
            <p class="anytime-tag">Start here</p>
            <h3>Anytime Orienteering</h3>
            <p class="anytime-blurb">The full guide, what's available, where, and how each format works.</p>
            <span class="anytime-go" aria-hidden="true">Read the guide →</span>
          </a>
        </li>
        <li>
          <a class="anytime-card" href="/information/permanent-orienteering-courses">
            <p class="anytime-tag">7 local courses</p>
            <h3>Permanent courses (POCs)</h3>
            <p class="anytime-blurb">Fixed posts in local parks: Towneley, Witton, Peel, Marl Pits, Wycoller, Roddlesworth and Gawthorpe Hall. Pick up a map and go.</p>
            <span class="anytime-go" aria-hidden="true">Find a POC →</span>
          </a>
        </li>
        <li>
          <a class="anytime-card anytime-card--maprun" href="/information/maprun-orienteering-courses">
            <div class="anytime-card-head">
              <img class="anytime-icon" src="/assets/Maprun-logo.png" alt="" aria-hidden="true" width="44" height="44">
              <p class="anytime-tag">On your phone</p>
            </div>
            <h3>MapRun courses</h3>
            <p class="anytime-blurb">Free smartphone app, your phone beeps when you reach each control. Dozens of courses across East Lancashire.</p>
            <span class="anytime-go" aria-hidden="true">Browse MapRun courses →</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <!-- ─────────────────────────── SOCIAL STRIP -->
  <section class="social-strip" aria-label="Follow us on social media">
    <div class="social-wrap">
      <div class="social-copy">
        <p class="eyebrow">Stay in touch</p>
        <h2>Event updates, photos, and last-minute changes.</h2>
        <p>Weather calls, course photos, and the post-race chat all live on our socials. Give us a follow so you don't miss the shout about tomorrow's event.</p>
      </div>
      <div class="social-buttons">
        <a class="social-btn" href="https://www.facebook.com/pendleorienteer/" rel="noopener" aria-label="Follow Pendle Forest Orienteers on Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13 22v-8h3l1-4h-4V7.5c0-1.2.4-2 2-2h2V2h-3c-2.8 0-4.5 1.6-4.5 4.5V10H6v4h3.5v8H13z"/>
          </svg>
          <span>
            <strong>Follow on Facebook</strong>
            <span class="handle">@pendleorienteer</span>
          </span>
        </a>
        <a class="social-btn" href="https://www.instagram.com/pendleforestorienteerers/" rel="noopener" aria-label="Follow Pendle Forest Orienteers on Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="4.5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          <span>
            <strong>Follow on Instagram</strong>
            <span class="handle">@pendleforestorienteerers</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── WIDER SPORT (British Orienteering) -->
  <section class="wider-sport" aria-label="British Orienteering news">
    <div class="ws-grid">
      <div class="ws-brand">
        <a class="bo-logo" href="https://www.britishorienteering.org.uk/" rel="noopener" aria-label="British Orienteering">
          <img src="/assets/british-orienteering.svg" alt="British Orienteering" width="180" height="48">
        </a>
        <p>PFO is a member club of British Orienteering, the national governing body for the sport in the UK. Headlines below pull from their news feed and refresh automatically.</p>
      </div>

      <div class="ws-feed">
        <p class="eyebrow">From the wider sport</p>
        <ul>
          {boNews.map(item => (
            <li>
              <time datetime={item.date.toISOString().slice(0, 10)}>{fmtBoDate(item.date)}</time>
              <h3><a href={item.url.startsWith('http') ? item.url : `https://www.britishorienteering.org.uk${item.url.startsWith('/') ? '' : '/'}${item.url}`} target="_blank" rel="noopener noreferrer">{item.title}</a></h3>
              <span class="read">Read →</span>
            </li>
          ))}
        </ul>
        <p class="ws-footer"><a href="https://www.britishorienteering.org.uk/news_archive" rel="noopener">All BO news →</a></p>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── LATEST + NEWCOMERS -->
  <section class="bottom-split">
    {latestNews && (
      <article class="featured-news">
        <a class="news-image" href={`/news/${latestNews.id}`} aria-label={latestNews.data.title}>
          {latestNews.data.heroImage && (
            <img src={latestNews.data.heroImage} alt={latestNews.data.heroImageAlt ?? ""}>
          )}
          <p class="news-caption">{fmtNewsCaption(latestNews.data.date)}</p>
        </a>
        <div class="news-body">
          <p class="eyebrow">Latest news</p>
          <h2>{latestNews.data.title}</h2>
          <p>{latestNews.data.summary}</p>
          <a class="more" href={`/news/${latestNews.id}`}>Read the story →</a>
        </div>
      </article>
    )}

    <aside class="newcomer-cta">
      <p class="eyebrow">Never tried this?</p>
      <h2>The sport of finding your way, <em>at your own pace</em>.</h2>
      <p>Orienteering is running, or walking, with a map and compass, navigating between checkpoints in a wood or a town. No special kit. No fitness minimum. Fastest round wins, but most people are just trying to beat their own time.</p>
      <a class="btn" href="/newcomers">How it works →</a>
    </aside>
  </section>

</main>

</Layout>
