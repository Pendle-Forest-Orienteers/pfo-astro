---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// ─────── Data
const allMaps = (await getCollection('maps'))
  .filter(m => !m.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Subset of mapped areas that have a permanent orienteering course (POC)
const pocMaps = allMaps.filter(m => m.data.permanentCourse);

// Group by terrain
const terrainOrder = ['urban', 'parkland', 'forest', 'moorland', 'mtbo', 'mixed'] as const;
const terrainLabel: Record<string, string> = {
  urban: 'Urban',
  parkland: 'Parkland',
  forest: 'Forest',
  moorland: 'Moorland',
  mtbo: 'Mountain bike',
  mixed: 'Mixed terrain',
};
const terrainBlurb: Record<string, string> = {
  urban: 'Streets, housing estates, town parks. Quick decisions, lots of cut-throughs.',
  parkland: 'Mature parks and school grounds. Friendly to newcomers and families.',
  forest: 'Plantation and mixed woodland. Real navigation, careful contour reading.',
  moorland: 'Open hill country, rough grass and heather. Lancashire at its best.',
  mtbo: 'Mountain bike orienteering. Rideable forest tracks and singletrack.',
  mixed: 'Combinations of the above.',
};

const grouped = terrainOrder.map(t => ({
  terrain: t,
  maps: allMaps.filter(m => m.data.terrain === t),
})).filter(g => g.maps.length > 0);
---
<Layout
  title="Mapped areas — Pendle Forest Orienteers"
  description="The PFO mapped-areas library — every venue PFO has surveyed across East Lancashire, plus permanent courses you can run any time."
>

<main id="main">

  <!-- ─────────────────────────── Page hero -->
  <section class="page-hero">
    <div class="page-hero-wrap">
      <p class="eyebrow rise d-1">Mapped areas</p>
      <h1 class="rise d-2">{allMaps.length} mapped areas across East Lancashire.</h1>
      <p class="page-lede rise d-3">
        Every venue PFO has surveyed and run on, from town-centre street-Os to open moorland fells.
        For previous courses and routes, head to <a href="https://www.pfo.routegadget.co.uk/rg2/" rel="noopener" class="rg-link">PFO RouteGadget →</a>
      </p>

      <nav class="terrain-jump rise d-4" aria-label="Jump to section">
        {pocMaps.length > 0 && (
          <a href="#permanent-courses" class="poc-jump">⭐ Permanent courses ({pocMaps.length})</a>
        )}
        {grouped.map(g => (
          <a href={`#${g.terrain}`}>{terrainLabel[g.terrain]} ({g.maps.length})</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- ─────────────────────────── Permanent courses (POCs) — venues you can run any time -->
  {pocMaps.length > 0 && (
    <section id="permanent-courses" class="terrain-section terrain-poc">
      <div class="terrain-wrap">
        <div class="sec-head">
          <div>
            <p class="eyebrow">Permanent courses (POCs)</p>
            <p class="terrain-blurb">Mapped areas with permanent posts you can run any day of the week. Pick up the map, find the controls in any order, no event required. See the <a href="/information/anytime-orienteering">Anytime Orienteering page</a> for MapRun courses too.</p>
          </div>
          <span class="sec-count">{pocMaps.length} map{pocMaps.length === 1 ? '' : 's'}</span>
        </div>
        <ul class="map-grid">
          {pocMaps.map(m => (
            <li>
              <a class="map-card" href={`/maps/${m.id}`}>
                <div class="map-card-image">
                  <img src={m.data.image} alt={m.data.imageAlt ?? m.data.title} loading="lazy">
                </div>
                <div class="map-card-body">
                  <h3>{m.data.title}</h3>
                  {m.data.nearTown && <p class="map-card-near">{m.data.nearTown}</p>}
                  <p class="map-card-summary">{m.data.summary}</p>
                  <span class="permanent-tag">Permanent course</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ─────────────────────────── Map sections by terrain -->
  {grouped.map(({ terrain, maps }) => (
    <section id={terrain} class={`terrain-section terrain-${terrain}`}>
      <div class="terrain-wrap">
        <div class="sec-head">
          <div>
            <p class="eyebrow">{terrainLabel[terrain]}</p>
            <p class="terrain-blurb">{terrainBlurb[terrain]}</p>
          </div>
          <span class="sec-count">{maps.length} map{maps.length === 1 ? '' : 's'}</span>
        </div>
        <ul class="map-grid">
          {maps.map(m => (
            <li>
              <a class="map-card" href={`/maps/${m.id}`}>
                <div class="map-card-image">
                  <img src={m.data.image} alt={m.data.imageAlt ?? m.data.title} loading="lazy">
                </div>
                <div class="map-card-body">
                  <h3>{m.data.title}</h3>
                  {m.data.nearTown && <p class="map-card-near">{m.data.nearTown}</p>}
                  <p class="map-card-summary">{m.data.summary}</p>
                  {m.data.permanentCourse && <span class="permanent-tag">Permanent course</span>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

</main>

</Layout>

<style>
  /* ─────────────────────────── Page hero */
  .page-hero {
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    padding: clamp(40px, 5vw, 80px) var(--pad-x) clamp(36px, 4vw, 60px);
  }
  .page-hero-wrap { max-width: var(--max-w); margin: 0 auto; }
  .page-hero .eyebrow { color: var(--gold-muted); margin-bottom: 18px; }
  .page-hero .eyebrow::before { background: var(--plum); }
  .page-hero h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(34px, 5vw, 60px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    margin: 0 0 20px 0;
    color: var(--ink);
    max-width: 22ch;
  }
  .page-lede {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0 0 24px 0;
  }
  .terrain-jump {
    display: flex; flex-wrap: wrap;
    gap: 10px 14px;
    align-items: center;
  }
  .terrain-jump a {
    font-family: var(--ff-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 12px;
    background: var(--paper);
    border: 1px solid var(--rule-2);
    color: var(--ink);
    transition: background .18s, color .18s;
  }
  .terrain-jump a:hover { background: var(--plum); color: var(--paper); border-color: var(--plum); }

  /* ─────────────────────────── Terrain sections */
  .terrain-section {
    padding: clamp(40px, 5vw, 64px) var(--pad-x);
  }
  .terrain-section:nth-child(even) { background: var(--paper-2); }
  .terrain-wrap { max-width: var(--max-w); margin: 0 auto; }
  .sec-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--ink);
    gap: 16px;
  }
  .sec-head .eyebrow {
    margin-bottom: 6px;
    color: var(--gold-muted);
  }
  .sec-head .eyebrow::before { background: var(--plum); }
  .terrain-blurb {
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0;
    max-width: 50ch;
  }
  .sec-count {
    font-family: var(--ff-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─────────────────────────── Map grid */
  .map-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }
  .map-card {
    display: block;
    background: var(--paper);
    color: var(--ink);
    transition: transform .22s ease, box-shadow .22s ease;
    border: 1px solid var(--rule);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .map-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -20px rgba(27, 59, 98, 0.4);
    border-color: var(--rule-2);
  }
  .map-card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
  }
  .map-card-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .map-card-body {
    padding: 16px 18px 18px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .map-card-body h3 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: 19px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 36, "SOFT" 20;
    margin: 0 0 4px 0;
    color: var(--ink);
  }
  .map-card-near {
    font-family: var(--ff-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-muted);
    margin: 0 0 8px 0;
  }
  .map-card-summary {
    font-size: 14px;
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0;
  }
  .permanent-tag {
    display: inline-block;
    margin-top: 10px;
    padding: 3px 10px;
    background: var(--plum);
    color: var(--paper);
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    align-self: flex-start;
  }

  @media (max-width: 720px) {
    .map-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
    .sec-head { flex-direction: column; gap: 10px; }
    .terrain-jump a { font-size: 10px; padding: 5px 10px; }
  }
</style>
