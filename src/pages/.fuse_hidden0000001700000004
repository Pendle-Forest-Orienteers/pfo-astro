---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

// ─────── Data
const allMaps = (await getCollection('maps'))
  .filter(m => !m.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Subset of mapped areas that have a permanent orienteering course (POC)
const pocMaps = allMaps.filter(m => m.data.permanentCourse);

// Public RouteGadget index — every map card links here. Committee can later
// add a per-map `routeGadgetUrl` field if they want specific RG entries.
const ROUTEGADGET_URL = "https://www.pfo.routegadget.co.uk/rg2/";

// Group by terrain
const terrainOrder = ['urban', 'parkland', 'forest', 'moorland', 'mtbo', 'mixed'] as const;
const terrainLabel: Record<string, string> = {
  urban: 'Urban',
  parkland: 'Parkland',
  forest: 'Forest',
  moorland: 'Moorland',
  mtbo: 'Mountain bike',
  mixed: 'Mixed terrain',
};
const terrainBlurb: Record<string, string> = {
  urban: 'Streets, housing estates, town parks. Quick decisions, lots of cut-throughs.',
  parkland: 'Mature parks and school grounds. Friendly to newcomers and families.',
  forest: 'Plantation and mixed woodland. Real navigation, careful contour reading.',
  moorland: 'Open hill country, rough grass and heather. Lancashire at its best.',
  mtbo: 'Mountain bike orienteering. Rideable forest tracks and singletrack.',
  mixed: 'Combinations of the above.',
};

const grouped = terrainOrder.map(t => ({
  terrain: t,
  maps: allMaps.filter(m => m.data.terrain === t),
})).filter(g => g.maps.length > 0);
---
<Layout
  title="Mapped areas — Pendle Forest Orienteers"
  description="The PFO mapped-areas library — every venue PFO has surveyed across East Lancashire, plus permanent courses you can run any time."
>

<main id="main">

  <!-- ─────────────────────────── Page hero -->
  <PageHero
    page="maps"
    eyebrow="Mapped areas"
    heading={`${allMaps.length} mapped areas across East Lancashire.`}
  >
    <p class="page-lede rise d-3">
      Every venue PFO has surveyed and run on, from town-centre street-Os to open moorland fells.
      For previous courses and routes, head to <a href="https://www.pfo.routegadget.co.uk/rg2/" rel="noopener" class="rg-link">PFO RouteGadget →</a>
    </p>

    <nav class="terrain-jump rise d-4" aria-label="Jump to section">
      {pocMaps.length > 0 && (
        <a href="#permanent-courses" class="poc-jump">⭐ Permanent courses ({pocMaps.length})</a>
      )}
      {grouped.map(g => (
        <a href={`#${g.terrain}`}>{terrainLabel[g.terrain]} ({g.maps.length})</a>
      ))}
    </nav>
  </PageHero>

  <!-- ─────────────────────────── Permanent courses (POCs) — venues you can run any time -->
  {pocMaps.length > 0 && (
    <section id="permanent-courses" class="terrain-section terrain-poc">
      <div class="terrain-wrap">
        <div class="sec-head">
          <div>
            <p class="eyebrow">Permanent courses (POCs)</p>
            <p class="terrain-blurb">Mapped areas with permanent posts you can run any day of the week. Pick up the map, find the controls in any order, no event required. See the <a href="/information/anytime-orienteering">Anytime Orienteering page</a> for MapRun courses too.</p>
          </div>
          <span class="sec-count">{pocMaps.length} map{pocMaps.length === 1 ? '' : 's'}</span>
        </div>
        <ul class="map-grid">
          {pocMaps.map(m => (
            <li>
              <a class="map-card map-card--poc" href={`/maps/${m.id}`}>
                <div class="map-card-body">
                  {m.data.nearTown && <p class="map-card-near">{m.data.nearTown}</p>}
                  <h3>{m.data.title}</h3>
                  <p class="map-card-summary">{m.data.summary}</p>
                  <div class="map-card-meta">
                    <span class="permanent-tag">Permanent course</span>
                    {m.data.scale && <span class="scale-tag">{m.data.scale}</span>}
                  </div>
                </div>
                <span class="map-card-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ─────────────────────────── Map sections by terrain -->
  {grouped.map(({ terrain, maps }) => (
    <section id={terrain} class={`terrain-section terrain-${terrain}`}>
      <div class="terrain-wrap">
        <div class="sec-head">
          <div>
            <p class="eyebrow">{terrainLabel[terrain]}</p>
            <p class="terrain-blurb">{terrainBlurb[terrain]}</p>
          </div>
          <span class="sec-count">{maps.length} map{maps.length === 1 ? '' : 's'}</span>
        </div>
        <ul class="map-grid">
          {maps.map(m => (
            <li>
              <a class="map-card" href={`/maps/${m.id}`}>
                <div class="map-card-body">
                  {m.data.nearTown && <p class="map-card-near">{m.data.nearTown}</p>}
                  <h3>{m.data.title}</h3>
                  <p class="map-card-summary">{m.data.summary}</p>
                  <div class="map-card-meta">
                    {m.data.permanentCourse && <span class="permanent-tag">Permanent course</span>}
                    {m.data.scale && <span class="scale-tag">{m.data.scale}</span>}
                  </div>
                </div>
                <span class="map-card-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

</main>

</Layout>

<style>
  /* ─────────────────────────── Page hero */
  .page-hero {
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    padding: clamp(40px, 5vw, 80px) var(--pad-x) clamp(36px, 4vw, 60px);
  }
  .page-hero-wrap { max-width: var(--max-w); margin: 0 auto; }
  .page-hero .eyebrow { color: var(--gold-muted); margin-bottom: 18px; }
  .page-hero .eyebrow::before { background: var(--plum); }
  .page-hero h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(34px, 5vw, 60px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    margin: 0 0 20px 0;
    color: var(--ink);
    max-width: 22ch;
  }
  .page-lede {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0 0 24px 0;
  }
  .terrain-jump {
    display: flex; flex-wrap: wrap;
    gap: 10px 14px;
    align-items: center;
  }
  .terrain-jump a {
    font-family: var(--ff-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 12px;
    background: var(--paper);
    border: 1px solid var(--rule-2);
    color: var(--ink);
    transition: background .18s, color .18s;
  }
  .terrain-jump a:hover { background: var(--plum); color: var(--paper); border-color: var(--plum); }

  /* ─────────────────────────── Terrain sections */
  .terrain-section {
    padding: clamp(40px, 5vw, 64px) var(--pad-x);
  }
  .terrain-section:nth-child(even) { background: var(--paper-2); }
  .terrain-wrap { max-width: var(--max-w); margin: 0 auto; }
  .sec-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--ink);
    gap: 16px;
  }
  .sec-head .eyebrow {
    margin-bottom: 6px;
    color: var(--gold-muted);
  }
  .sec-head .eyebrow::before { background: var(--plum); }
  .terrain-blurb {
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0;
    max-width: 50ch;
  }
  .sec-count {
    font-family: var(--ff-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─────────────────────────── Map grid — text-only clickable blocks
     We deliberately don't show the orienteering map images (licensing
     held by individual surveyors). Each block links through to the map's
     detail page where members can find the RouteGadget link, OS grid ref
     and any access notes. */
  .map-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
  }
  .map-grid > li { display: block; }
  .map-card {
    position: relative;
    display: flex;
    align-items: stretch;
    gap: 18px;
    background: var(--paper);
    color: var(--ink);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--rule-2);
    padding: 18px 20px 18px 22px;
    height: 100%;
    transition: border-left-color .18s ease, background .18s ease, transform .18s ease;
  }
  .map-card:hover {
    border-left-color: var(--plum);
    background: var(--paper-2);
    transform: translateX(2px);
  }
  .map-card:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
  .map-card--poc {
    border-left-color: var(--plum);
    background: linear-gradient(to right, var(--paper-2), var(--paper) 60%);
  }
  .map-card--poc:hover {
    border-left-color: var(--plum-deep);
  }
  .map-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .map-card-near {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-muted);
    margin: 0;
  }
  .map-card-body h3 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: 19px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 36, "SOFT" 20;
    margin: 0;
    color: var(--ink);
  }
  .map-card-summary {
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 2px 0 0 0;
  }
  .map-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }
  .permanent-tag {
    display: inline-block;
    padding: 3px 10px;
    background: var(--plum);
    color: var(--paper);
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .scale-tag {
    display: inline-block;
    padding: 3px 10px;
    background: var(--paper-2);
    color: var(--ink-soft);
    border: 1px solid var(--rule);
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .map-card--poc .scale-tag { background: var(--paper); }
  .map-card-arrow {
    align-self: center;
    font-family: var(--ff-display);
    font-size: 22px;
    color: var(--ink-mute);
    transition: color .18s ease, transform .18s ease;
  }
  .map-card:hover .map-card-arrow {
    color: var(--plum);
    transform: translateX(3px);
  }

  @media (max-width: 720px) {
    .map-grid { grid-template-columns: 1fr; gap: 10px; }
    .sec-head { flex-direction: column; gap: 10px; }
    .terrain-jump a { font-size: 10px; padding: 5px 10px; }
    .map-card { padding: 16px 18px 16px 20px; }
  }
</style>
