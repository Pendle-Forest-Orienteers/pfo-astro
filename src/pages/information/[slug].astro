---
import Layout from '../../layouts/Layout.astro';
import Attachments from '../../components/Attachments.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('infoPages');
  return pages
    .filter(p => !p.data.draft)
    .map(p => ({ params: { slug: p.id }, props: { page: p } }));
}

const { page } = Astro.props;
const { Content } = await render(page);

// Other info pages in the same section, for the sidebar
const allPages = (await getCollection('infoPages'))
  .filter(p => !p.data.draft && p.id !== page.id)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const sectionLabel: Record<string, string> = {
  governance: 'Governance',
  safety: 'Safety',
  participation: 'Participation',
  members: 'Members',
  admin: 'Admin',
};

const fmtReviewed = (d: Date) => new Intl.DateTimeFormat('en-GB', {
  month: 'long', year: 'numeric'
}).format(d);

// BreadcrumbList JSON-LD — helps search results render a (Home › Information ›
// Page) trail and reinforces the site's hierarchy for crawlers.
const siteUrl = Astro.site ?? new URL("https://pfo.org.uk");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl.toString() },
    { "@type": "ListItem", position: 2, name: "Information", item: new URL("/information", siteUrl).toString() },
    { "@type": "ListItem", position: 3, name: page.data.title, item: canonical },
  ],
};
---
<Layout
  title={`${page.data.title} — Information — PFO`}
  description={page.data.summary}
>

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>
</Fragment>

<main id="main">

  <section class="info-page-hero">
    <div class="info-page-hero-wrap">
      <a class="back-link" href="/information">← All information</a>
      {page.data.section && <p class="eyebrow">{sectionLabel[page.data.section]}</p>}
      <h1>{page.data.title}</h1>
      <p class="info-summary">{page.data.summary}</p>
      {page.data.lastReviewed && (
        <p class="info-meta">Last reviewed: <time datetime={page.data.lastReviewed.toISOString()}>{fmtReviewed(page.data.lastReviewed)}</time></p>
      )}
    </div>
  </section>

  <section class={`info-page-body ${page.data.wideLayout ? 'info-page-body--wide' : ''}`}>
    <div class="info-page-body-wrap">
      {page.data.wideLayout && (
        <details class="info-page-dropdown">
          <summary>
            <span class="dropdown-label">Other information</span>
            <span class="dropdown-arrow" aria-hidden="true">▾</span>
          </summary>
          <ul>
            {allPages.map(p => (
              <li><a href={`/information/${p.id}`}>{p.data.title}</a></li>
            ))}
            <li><a class="all-info-link" href="/information">All information →</a></li>
          </ul>
        </details>
      )}

      <article class="info-prose">
        <Content />
        {page.data.attachments && page.data.attachments.length > 0 && (
          <Attachments attachments={page.data.attachments} />
        )}
      </article>

      {!page.data.wideLayout && (
        <aside class="info-page-aside">
          <p class="aside-label">Other information</p>
          <ul>
            {allPages.map(p => (
              <li><a href={`/information/${p.id}`}>{p.data.title}</a></li>
            ))}
            <li><a href="/information">All information →</a></li>
          </ul>
        </aside>
      )}
    </div>
  </section>

</main>

</Layout>

<style>
  .info-page-hero {
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    padding: clamp(28px, 4vw, 48px) var(--pad-x) clamp(28px, 3vw, 40px);
  }
  .info-page-hero-wrap {
    max-width: 760px;
    margin: 0 auto;
  }
  .back-link {
    display: inline-block;
    font-family: var(--ff-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 24px;
    transition: color .18s ease;
  }
  .back-link:hover { color: var(--plum); }
  .eyebrow {
    font-family: var(--ff-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-muted);
    display: inline-flex; align-items: center; gap: 10px;
    margin: 0 0 16px 0;
  }
  .eyebrow::before {
    content: "";
    width: 8px; height: 8px;
    background: var(--plum);
    transform: rotate(45deg);
    clip-path: polygon(0 0, 100% 100%, 0 100%);
  }
  .info-page-hero h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    color: var(--ink);
    margin: 0 0 14px 0;
  }
  .info-summary {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 14px 0;
    max-width: 60ch;
  }
  .info-meta {
    font-family: var(--ff-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--ink-mute);
    margin: 0;
  }

  .info-page-body { padding: clamp(40px, 5vw, 64px) var(--pad-x); }
  .info-page-body-wrap {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 240px;
    gap: clamp(32px, 4vw, 56px);
    align-items: start;
  }
  /* Wide layout (used for pages with wide tables — e.g. POCs).
     Single full-width column, sibling links collapse into a dropdown
     above the prose. */
  .info-page-body--wide .info-page-body-wrap {
    display: block;
  }
  .info-page-dropdown {
    margin: 0 0 28px 0;
    background: var(--paper-2);
    border-left: 3px solid var(--plum);
  }
  .info-page-dropdown > summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 18px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background .18s ease;
  }
  .info-page-dropdown > summary::-webkit-details-marker { display: none; }
  .info-page-dropdown > summary:hover { background: var(--paper-3); }
  .info-page-dropdown > summary:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: -2px;
  }
  .dropdown-label {
    font-family: var(--ff-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .dropdown-arrow {
    font-family: var(--ff-display);
    font-size: 16px;
    color: var(--plum);
    transition: transform .22s ease;
  }
  .info-page-dropdown[open] .dropdown-arrow { transform: rotate(180deg); }
  .info-page-dropdown ul {
    list-style: none;
    padding: 6px 18px 16px;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 4px 24px;
    border-top: 1px solid var(--rule);
  }
  .info-page-dropdown li { margin: 0; }
  .info-page-dropdown a {
    display: block;
    padding: 6px 0;
    font-size: 14px;
    color: var(--ink);
    border-bottom: 1px solid transparent;
    transition: color .18s, border-color .18s;
  }
  .info-page-dropdown a:hover { color: var(--plum); border-bottom-color: var(--plum); }
  .info-page-dropdown .all-info-link { color: var(--plum); font-weight: 500; }

  /* The prose container fills its grid column so wide tables (e.g. MapRun
     courses, POC courses) can use the full available width. Individual
     text elements get their own narrow max-width below for readability. */
  .info-prose { min-width: 0; }
  .info-prose :global(h2) {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(22px, 2vw, 26px);
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 36, "SOFT" 20;
    color: var(--navy);
    margin: 32px 0 12px 0;
    max-width: 30ch;
  }
  .info-prose :global(h2:first-child) { margin-top: 0; }
  .info-prose :global(h3) {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: 19px;
    color: var(--ink);
    margin: 24px 0 8px 0;
    max-width: 40ch;
  }
  .info-prose :global(p) {
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink);
    margin: 0 0 16px 0;
    max-width: 65ch;
  }
  .info-prose :global(strong) { font-weight: 500; }
  .info-prose :global(ul), .info-prose :global(ol) {
    margin: 0 0 18px 1.4em;
    padding: 0;
    max-width: 65ch;
  }
  .info-prose :global(li) {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink);
    margin-bottom: 6px;
  }
  .info-prose :global(a) {
    color: var(--navy);
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-underline-offset: 3px;
  }
  .info-prose :global(a:hover) { color: var(--plum); }

  /* Bullet-list links to documents (PDFs, Google Drive maps) get a small
     file-style icon so the page reads as a proper list of downloads. */
  .info-prose :global(li > a[href$=".pdf"]),
  .info-prose :global(li > a[href*="drive.google.com"]),
  .info-prose :global(li > a[href$=".docx"]),
  .info-prose :global(li > a[href$=".xlsx"]) {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color .18s, border-color .18s;
  }
  .info-prose :global(li > a[href$=".pdf"])::before,
  .info-prose :global(li > a[href*="drive.google.com"])::before,
  .info-prose :global(li > a[href$=".docx"])::before,
  .info-prose :global(li > a[href$=".xlsx"])::before {
    content: "";
    display: inline-block;
    width: 14px;
    height: 16px;
    flex: 0 0 14px;
    background-color: var(--gold-muted);
    /* Inline SVG of a generic document icon — masked so it picks up colour */
    -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 14 16' fill='none' stroke='currentColor' stroke-width='1.4'><path d='M2 1.5h7l3 3v10a.5.5 0 01-.5.5h-9.5a.5.5 0 01-.5-.5V2a.5.5 0 01.5-.5z'/><path d='M9 1.5V4.5h3'/><line x1='3.5' y1='8' x2='10.5' y2='8'/><line x1='3.5' y1='10.5' x2='10.5' y2='10.5'/><line x1='3.5' y1='13' x2='8' y2='13'/></svg>");
    mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 14 16' fill='none' stroke='currentColor' stroke-width='1.4'><path d='M2 1.5h7l3 3v10a.5.5 0 01-.5.5h-9.5a.5.5 0 01-.5-.5V2a.5.5 0 01.5-.5z'/><path d='M9 1.5V4.5h3'/><line x1='3.5' y1='8' x2='10.5' y2='8'/><line x1='3.5' y1='10.5' x2='10.5' y2='10.5'/><line x1='3.5' y1='13' x2='8' y2='13'/></svg>");
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    transform: translateY(2px);
  }
  .info-prose :global(li > a[href$=".pdf"]:hover),
  .info-prose :global(li > a[href*="drive.google.com"]:hover),
  .info-prose :global(li > a[href$=".docx"]:hover),
  .info-prose :global(li > a[href$=".xlsx"]:hover) {
    color: var(--plum);
    border-bottom-color: var(--plum);
  }
  .info-prose :global(li > a[href$=".pdf"]:hover)::before,
  .info-prose :global(li > a[href*="drive.google.com"]:hover)::before,
  .info-prose :global(li > a[href$=".docx"]:hover)::before,
  .info-prose :global(li > a[href$=".xlsx"]:hover)::before {
    background-color: var(--plum);
  }

  /* Tighten list spacing on POC-style download lists so the icons + lines
     read as a list rather than dense prose. */
  .info-prose :global(ul) :global(li) {
    margin-bottom: 4px;
  }

  /* MapRun (and similar) logo inside info-page prose. Floats right of
     the surrounding paragraph on wider screens; stacks on phones.
     The size is driven by the inline width/height attributes on the
     <img> so different pages can use different sizes. */
  .info-prose :global(.maprun-mark) {
    float: right;
    margin: 0 0 12px 24px;
    border-radius: 18%;
    box-shadow: 0 6px 18px -8px rgba(27, 59, 98, 0.3);
  }
  @media (max-width: 600px) {
    .info-prose :global(.maprun-mark) {
      float: none;
      display: block;
      margin: 4px 0 16px 0;
    }
  }

  /* App Store + Google Play download buttons */
  .info-prose :global(.store-buttons) {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 24px 0 28px 0;
    clear: both;
  }
  .info-prose :global(.store-btn) {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px 10px 16px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 10px;
    text-decoration: none;
    transition: background .18s ease, transform .18s ease;
    min-width: 200px;
  }
  .info-prose :global(.store-btn:hover) {
    background: var(--navy);
    color: var(--paper);
    transform: translateY(-2px);
    border-color: var(--navy);
  }
  .info-prose :global(.store-btn-icon) {
    width: 28px;
    height: 28px;
    flex: 0 0 28px;
  }
  .info-prose :global(.store-btn-copy) {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .info-prose :global(.store-btn-eyebrow) {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(244, 237, 224, 0.75);
    margin-bottom: 2px;
  }
  .info-prose :global(.store-btn-name) {
    font-family: var(--ff-display);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--paper);
  }

  /* Tables — horizontally scrollable inside their column when narrow,
     so a wide table (MapRun courses, POC courses) never overflows under
     the sticky sidebar. */
  .info-prose :global(table) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 18px 0 24px 0;
    font-size: 14px;
    -webkit-overflow-scrolling: touch;
  }
  .info-prose :global(thead) { background: var(--paper-2); }
  .info-prose :global(th) {
    text-align: left;
    font-family: var(--ff-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 10px 12px;
    border-bottom: 1px solid var(--ink);
    vertical-align: top;
  }
  .info-prose :global(td) {
    padding: 10px 12px;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    line-height: 1.45;
    color: var(--ink);
    min-width: 120px;
  }
  .info-prose :global(tr:hover td) { background: var(--paper-2); }
  .info-prose :global(table a) { word-break: break-word; }

  .info-page-aside {
    background: var(--paper-2);
    padding: 18px;
    border-left: 3px solid var(--plum);
    position: sticky;
    top: 24px;
    /* Cap height + scroll internally so a very long sidebar can't run
       past the page itself; also avoids any visual collision with wide
       tables in the prose column. */
    max-height: calc(100vh - 48px);
    overflow-y: auto;
  }
  .aside-label {
    font-family: var(--ff-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 12px 0;
  }
  .info-page-aside ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex; flex-direction: column;
    gap: 6px;
  }
  .info-page-aside a {
    display: block;
    padding: 4px 0;
    font-size: 14px;
    color: var(--ink);
    border-bottom: 1px solid transparent;
    transition: color .18s, border-color .18s;
  }
  .info-page-aside a:hover { color: var(--plum); border-bottom-color: var(--plum); }

  @media (max-width: 720px) {
    .info-page-body-wrap { grid-template-columns: 1fr; }
    .info-page-aside { position: static; }
  }
</style>
