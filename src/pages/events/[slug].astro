---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// ─────── Generate one page per event in the collection
export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(event => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const now = new Date();
const isUpcoming = event.data.entryCloseDate >= now;
const hasResults = event.data.results && event.data.results.length > 0;

// ─────── Date formatters
const fmtFullDate = (d: Date) => new Intl.DateTimeFormat('en-GB', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
}).format(d).replace(',', '');

const fmtDay = (d: Date) => new Intl.DateTimeFormat('en-GB', { day: 'numeric' }).format(d);
const fmtMonth = (d: Date) => new Intl.DateTimeFormat('en-GB', { month: 'long' }).format(d);
const fmtYear = (d: Date) => new Intl.DateTimeFormat('en-GB', { year: 'numeric' }).format(d);

const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

// ─────── Location helpers
const coords = event.data.coords;
const mapsLink = coords
  ? `https://www.google.com/maps/place/${coords.lat},${coords.lng}/@${coords.lat},${coords.lng},14z`
  : null;
const osmLink = coords
  ? `https://www.openstreetmap.org/?mlat=${coords.lat}&mlon=${coords.lng}&zoom=14`
  : null;
const streetmapLink = coords
  ? `https://www.streetmap.co.uk/loc/${coords.lat},${coords.lng}`
  : null;
const bingLink = coords
  ? `https://www.bing.com/maps/?v=2&lvl=14&style=s&cp=${coords.lat}~${coords.lng}&q=${coords.lat},${coords.lng}`
  : null;

// ─────── File-type label / icon
const fileTypeLabel = (t: string) => {
  switch (t) {
    case 'pdf': return 'PDF';
    case 'xlsx': return 'Excel';
    case 'csv': return 'CSV';
    case 'html': default: return 'View online';
  }
};

// ─────── Schema.org Event JSON-LD
// Google reads this and surfaces the event in event-rich-result cards.
// https://developers.google.com/search/docs/appearance/structured-data/event
const siteUrl = Astro.site ?? new URL("https://pfo.org.uk");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();

// Combine event date with start time, if provided. Otherwise use date at 00:00.
function combineDateAndTime(date: Date, displayTime?: string): string {
  if (!displayTime) return date.toISOString();
  // Parse "7:00pm" / "10:30am" into 24h and apply to the date
  const m = displayTime.trim().toLowerCase().match(/^(\d{1,2})(?::(\d{2}))?\s*(am|pm)?$/);
  if (!m) return date.toISOString();
  let hours = parseInt(m[1], 10);
  const mins = m[2] ? parseInt(m[2], 10) : 0;
  const meridiem = m[3];
  if (meridiem === 'pm' && hours < 12) hours += 12;
  if (meridiem === 'am' && hours === 12) hours = 0;
  const d = new Date(date);
  d.setHours(hours, mins, 0, 0);
  return d.toISOString();
}

const startIso = combineDateAndTime(event.data.date, event.data.startTime);

const eventJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  name: event.data.title,
  description: event.data.description ?? event.data.summary,
  startDate: startIso,
  eventStatus: event.data.cancelled
    ? "https://schema.org/EventCancelled"
    : "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  url: canonical,
  organizer: {
    "@type": "SportsOrganization",
    name: "Pendle Forest Orienteers",
    url: siteUrl.toString(),
  },
  sport: "Orienteering",
  location: {
    "@type": "Place",
    name: event.data.venue ?? event.data.location,
    address: {
      "@type": "PostalAddress",
      addressLocality: event.data.location,
      ...(event.data.postcode ? { postalCode: event.data.postcode } : {}),
      addressRegion: "Lancashire",
      addressCountry: "GB",
    },
    ...(coords ? {
      geo: {
        "@type": "GeoCoordinates",
        latitude: coords.lat,
        longitude: coords.lng,
      }
    } : {}),
  },
};

if (event.data.entryFee && event.data.siEntriesUrl) {
  eventJsonLd.offers = {
    "@type": "Offer",
    price: event.data.entryFee,
    priceCurrency: "GBP",
    availability: "https://schema.org/InStock",
    url: event.data.siEntriesUrl,
    validThrough: event.data.entryCloseDate.toISOString(),
  };
}
---
<Layout
  title={`${event.data.title} — ${fmtMonth(event.data.date)} ${fmtYear(event.data.date)} — PFO`}
  description={event.data.description ?? event.data.summary}
  ogType="article"
  publishedTime={event.data.date.toISOString()}
>

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)}></script>
</Fragment>

<main id="main">

  <!-- ─────────────────────────── Event hero -->
  <section class="ev-hero">
    <div class="ev-hero-wrap">
      <a class="back-link" href="/events">← All events</a>

      <div class="ev-hero-grid">
        <div class="ev-hero-left">
          <p class="eyebrow">
            {event.data.format}
            {event.data.location && <><span aria-hidden="true"> · </span>{event.data.location}</>}
            <span aria-hidden="true"> · </span>{capitalize(event.data.level)} level
          </p>
          <h1>{event.data.title}</h1>
          {event.data.cancelled && (
            <p class="cancelled-banner">Cancelled</p>
          )}
          {event.data.description && <p class="ev-hero-lede">{event.data.description}</p>}

          <dl class="ev-key-facts">
            <div>
              <dt>Date</dt>
              <dd>{fmtFullDate(event.data.date)}</dd>
            </div>
            {event.data.startTime && (
              <div>
                <dt>Start</dt>
                <dd>{event.data.startTime}</dd>
              </div>
            )}
            {event.data.duration && (
              <div>
                <dt>Duration</dt>
                <dd>{event.data.duration} min</dd>
              </div>
            )}
            {event.data.entryFee && (
              <div>
                <dt>Entry</dt>
                <dd>{event.data.entryFee}</dd>
              </div>
            )}
            {event.data.capacity && (
              <div>
                <dt>Capacity</dt>
                <dd>{event.data.capacity} entrants</dd>
              </div>
            )}
            {event.data.dogsAllowed && (
              <div>
                <dt>Dogs</dt>
                <dd>
                  {event.data.dogsAllowed === 'yes' && 'Welcome'}
                  {event.data.dogsAllowed === 'on-lead' && 'On lead only'}
                  {event.data.dogsAllowed === 'no' && 'Not permitted'}
                  {event.data.dogsAllowed === 'not-recommended' && 'Not recommended'}
                </dd>
              </div>
            )}
            {event.data.bofEventNumber && (
              <div>
                <dt>BOF event no.</dt>
                <dd class="mono">{event.data.bofEventNumber}</dd>
              </div>
            )}
            {event.data.venue && (
              <div class="full">
                <dt>Venue</dt>
                <dd>{event.data.venue}{event.data.postcode && <>, <span class="mono">{event.data.postcode}</span></>}</dd>
              </div>
            )}
          </dl>
        </div>

        <aside class="ev-hero-right">
          {isUpcoming && event.data.siEntriesUrl && !event.data.cancelled && (
            <div class="cta-card primary">
              <p class="cta-label">Online entry</p>
              <p class="cta-detail">Open until {fmtFullDate(event.data.entryCloseDate)}</p>
              <a class="btn btn-primary btn-full" href={event.data.siEntriesUrl} rel="noopener">
                Enter via SI Entries <span class="arrow">→</span>
              </a>
            </div>
          )}

          {isUpcoming && !event.data.siEntriesUrl && !event.data.cancelled && (
            <div class="cta-card neutral">
              <p class="cta-label">Online entry</p>
              <p class="cta-detail">Entry details to follow</p>
            </div>
          )}

          {!isUpcoming && hasResults && (
            <div class="cta-card primary">
              <p class="cta-label">Event finished</p>
              <p class="cta-detail">Results available below</p>
              <a class="btn btn-primary btn-full" href="#results">
                Jump to results <span class="arrow">↓</span>
              </a>
            </div>
          )}

          {!isUpcoming && !hasResults && (
            <div class="cta-card neutral">
              <p class="cta-label">Event finished</p>
              <p class="cta-detail">Results to follow</p>
            </div>
          )}

          {event.data.routeGadgetUrl && (
            <a class="link-row" href={event.data.routeGadgetUrl} rel="noopener">
              <span>View on RouteGadget</span>
              <span aria-hidden="true">→</span>
            </a>
          )}

          <button class="link-row print-btn" type="button" onclick="window.print()">
            <span>Print this page</span>
            <span aria-hidden="true">⎙</span>
          </button>
        </aside>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── Body content -->
  <section class="ev-body">
    <div class="ev-body-wrap">
      <article class="ev-prose">
        <Content />
      </article>

      <aside class="ev-meta">
        <div class="meta-block">
          <p class="meta-label">Location</p>
          <p class="meta-place">{event.data.location}</p>
          {coords && (
            <p class="meta-coord mono">{coords.lat.toFixed(5)}, {coords.lng.toFixed(5)}</p>
          )}
          {event.data.gridRef && (
            <p class="meta-postcode mono">OS {event.data.gridRef}</p>
          )}
          {event.data.postcode && (
            <p class="meta-postcode mono">{event.data.postcode}</p>
          )}
          {event.data.what3words && (
            <p class="meta-postcode">
              <a
                class="w3w"
                href={`https://what3words.com/${event.data.what3words}`}
                rel="noopener"
                target="_blank"
              >
                ///<span class="mono">{event.data.what3words}</span>
              </a>
            </p>
          )}
          {coords && (
            <ul class="map-links">
              <li><a href={mapsLink} rel="noopener" target="_blank">Google Maps →</a></li>
              <li><a href={osmLink} rel="noopener" target="_blank">OpenStreetMap →</a></li>
              <li><a href={streetmapLink} rel="noopener" target="_blank">Streetmap (OS 50k) →</a></li>
              <li><a href={bingLink} rel="noopener" target="_blank">Bing Maps (OS) →</a></li>
            </ul>
          )}
          {!coords && (
            <p class="meta-note">Coordinates and map links will appear here once the committee adds them.</p>
          )}
        </div>

        {(event.data.planner || event.data.controller || event.data.seriesOrganiser) && (
          <div class="meta-block">
            <p class="meta-label">Officials</p>
            <dl class="officials">
              {event.data.planner && (
                <>
                  <dt>Planner</dt>
                  <dd>{event.data.planner}</dd>
                </>
              )}
              {event.data.controller && (
                <>
                  <dt>Controller</dt>
                  <dd>{event.data.controller}</dd>
                </>
              )}
              {event.data.seriesOrganiser && (
                <>
                  <dt>Series organiser</dt>
                  <dd>{event.data.seriesOrganiser}</dd>
                </>
              )}
            </dl>
          </div>
        )}

        {event.data.dogNotes && (
          <div class="meta-block">
            <p class="meta-label">Dogs</p>
            <p class="meta-note">{event.data.dogNotes}</p>
          </div>
        )}

        <div class="meta-block">
          <p class="meta-label">Event level</p>
          <p>
            <span class={`level level-${event.data.level}`}>{capitalize(event.data.level)}</span>
          </p>
          <p class="meta-note">
            {event.data.level === 'local' && 'Low-key, ideal for newcomers.'}
            {event.data.level === 'regional' && 'Attracts orienteers from across the North West.'}
            {event.data.level === 'national' && 'High-quality competition drawing competitors from across the UK.'}
            {event.data.level === 'major' && 'A major event such as a British Championships or JK round.'}
          </p>
        </div>
      </aside>
    </div>
  </section>

  <!-- ─────────────────────────── Results files -->
  {hasResults && (
    <section id="results" class="ev-results">
      <div class="ev-results-wrap">
        <h2>Results</h2>
        <ul class="results-list">
          {event.data.results.map(file => (
            <li>
              <a href={file.url} rel="noopener">
                <span class="result-icon" data-type={file.type}>{fileTypeLabel(file.type)}</span>
                <span class="result-label">{file.label}</span>
                <span class="result-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

</main>

</Layout>

<style>
  .mono { font-family: var(--ff-mono); }

  /* ─────────────────────────── Hero */
  .ev-hero {
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    padding: clamp(28px, 4vw, 48px) var(--pad-x) clamp(40px, 5vw, 64px);
  }
  .ev-hero-wrap {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .back-link {
    display: inline-block;
    font-family: var(--ff-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 28px;
    transition: color .18s ease;
  }
  .back-link:hover { color: var(--plum); }

  .ev-hero-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: clamp(28px, 4vw, 56px);
    align-items: start;
  }

  .ev-hero-left .eyebrow {
    font-family: var(--ff-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-muted);
    margin: 0 0 18px 0;
  }
  .ev-hero-left .eyebrow span { color: var(--ink-mute); margin: 0 4px; }

  .ev-hero-left h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    margin: 0 0 16px 0;
    color: var(--ink);
  }

  .cancelled-banner {
    display: inline-block;
    background: var(--plum);
    color: var(--paper);
    padding: 6px 14px;
    font-family: var(--ff-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 16px 0;
  }

  .ev-hero-lede {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0 0 28px 0;
  }

  /* ─────────────────────────── Key facts */
  .ev-key-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 18px 28px;
    margin: 24px 0 0 0;
    padding-top: 22px;
    border-top: 1px solid var(--rule);
  }
  .ev-key-facts .full {
    grid-column: 1 / -1;
  }
  .ev-key-facts dt {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 4px 0;
  }
  .ev-key-facts dd {
    font-size: 15px;
    color: var(--ink);
    margin: 0;
    line-height: 1.35;
  }

  /* ─────────────────────────── CTA card on the right */
  .ev-hero-right { display: flex; flex-direction: column; gap: 14px; }
  .cta-card {
    background: var(--paper);
    padding: 22px 22px 20px;
    border-top: 4px solid var(--gold);
    box-shadow: 0 18px 40px -20px rgba(27, 59, 98, 0.45);
  }
  .cta-card.neutral {
    border-top-color: var(--rule-2);
    box-shadow: none;
  }
  .cta-card .cta-label {
    font-family: var(--ff-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-muted);
    margin: 0 0 6px 0;
  }
  .cta-card.neutral .cta-label { color: var(--ink-mute); }
  .cta-card .cta-detail {
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0 0 16px 0;
  }
  .cta-card .btn-primary {
    background: var(--gold);
    color: var(--ink);
    font-weight: 500;
    box-shadow: inset 0 -2px 0 rgba(12, 31, 58, 0.12);
  }
  .cta-card .btn-primary:hover {
    background: var(--gold-dark);
    color: var(--paper);
    box-shadow: none;
  }

  .link-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    background: var(--paper);
    color: var(--ink);
    font-size: 14px;
    font-weight: 500;
    transition: background .18s ease, color .18s ease;
  }
  .link-row:hover { background: var(--ink); color: var(--paper); }

  /* ─────────────────────────── Body */
  .ev-body {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(40px, 5vw, 72px) var(--pad-x);
  }
  .ev-body-wrap {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: clamp(32px, 4vw, 56px);
    align-items: start;
  }

  /* Article prose styles */
  .ev-prose :global(h1) { display: none; }
  .ev-prose :global(h2) {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(22px, 2vw, 28px);
    line-height: 1.15;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 36, "SOFT" 20;
    color: var(--navy);
    margin: 32px 0 14px 0;
  }
  .ev-prose :global(h2:first-child) { margin-top: 0; }
  .ev-prose :global(h3) {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: 19px;
    line-height: 1.2;
    color: var(--ink);
    margin: 24px 0 10px 0;
  }
  .ev-prose :global(p) {
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0 0 16px 0;
    max-width: 65ch;
  }
  .ev-prose :global(ul), .ev-prose :global(ol) {
    margin: 0 0 16px 1.4em;
    padding: 0;
  }
  .ev-prose :global(li) {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 6px;
  }
  .ev-prose :global(a) {
    color: var(--navy);
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
  }
  .ev-prose :global(a:hover) { color: var(--plum); }

  /* Aside / meta blocks */
  .ev-meta { display: flex; flex-direction: column; gap: 24px; position: sticky; top: 24px; }
  .meta-block {
    padding: 18px 18px;
    background: var(--paper-2);
    border-left: 3px solid var(--plum);
  }
  .meta-block .meta-label {
    font-family: var(--ff-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 8px 0;
  }
  .meta-coord, .meta-postcode {
    font-size: 14px;
    color: var(--ink);
    margin: 0 0 4px 0;
  }
  .meta-place {
    font-size: 14px;
    color: var(--ink);
    margin: 0 0 6px 0;
    font-weight: 500;
  }
  .meta-note {
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 8px 0 0 0;
  }
  .map-links {
    list-style: none;
    padding: 0;
    margin: 12px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .map-links a {
    font-family: var(--ff-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
  }
  .map-links a:hover { color: var(--plum); border-color: var(--plum); }

  /* what3words link in the location meta block */
  .w3w {
    font-size: 13px;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-2);
    padding-bottom: 1px;
    transition: color .18s ease, border-color .18s ease;
  }
  .w3w:hover { color: var(--plum); border-color: var(--plum); }

  /* Officials block — small dl in the meta sidebar */
  .officials {
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 4px 12px;
  }
  .officials dt {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    align-self: baseline;
  }
  .officials dd {
    margin: 0;
    font-size: 13px;
    color: var(--ink);
    line-height: 1.4;
  }

  /* ─────────────────────────── Results */
  .ev-results {
    background: var(--navy-deep);
    color: var(--paper);
    padding: clamp(40px, 5vw, 64px) var(--pad-x);
    border-top: 4px solid var(--gold);
  }
  .ev-results-wrap { max-width: var(--max-w); margin: 0 auto; }
  .ev-results h2 {
    font-family: var(--ff-display);
    font-weight: 500;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1;
    color: var(--paper);
    font-variation-settings: "opsz" 48, "SOFT" 20;
    margin: 0 0 24px 0;
  }
  .results-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }
  .results-list a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--paper);
    transition: background .18s ease;
  }
  .results-list a:hover { background: var(--gold); color: var(--ink); }
  .result-icon {
    display: inline-block;
    padding: 4px 10px;
    background: var(--gold);
    color: var(--ink);
    font-family: var(--ff-mono);
