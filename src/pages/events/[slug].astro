---
import Layout from '../../layouts/Layout.astro';
import Attachments from '../../components/Attachments.astro';
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';

// ─────── Generate one page per event in the collection
// Hidden events get no page generated, their slug 404s on the public site
// even if someone has the direct URL. Un-hide in the CMS to bring it back.
export async function getStaticPaths() {
  const events = await getCollection('events');
  return events
    .filter(event => !event.data.hidden)
    .map(event => ({
      params: { slug: event.id },
      props: { event },
    }));
}

const { event } = Astro.props;
const { Content } = await render(event);

import { isEventUpcoming } from '../../lib/event-state';
const now = new Date();
// "Open for entry" — controls whether the Enter CTAs are shown.
const isOpenForEntry = event.data.entryCloseDate >= now;
// "Upcoming" — controls whether the event is in the future overall.
// An event that's closed for entry but still hasn't happened yet is
// still considered upcoming. Flips at the event's start time, or 8pm
// on the event date if no start time is set.
const isUpcoming = isEventUpcoming(event.data, now);
// Filter out any results entries marked hidden in the CMS so they don't
// appear on the public page (the entry stays in the markdown for later).
const visibleResults = (event.data.results ?? []).filter(r => !r.hidden);
const hasResults = visibleResults.length > 0;
// True when a post-event report has been written in the CMS. Renders a
// "Report" button next to the results files that links to a separate
// page at /events/{slug}/report.
const hasReport = typeof event.data.report === 'string' && event.data.report.trim().length > 0;

// ─────── Disclaimer (yellow box at the bottom of the body)
// Every event shows the club-wide BO insurance notice by default.
// Editors can replace it on a per-event basis by ticking the
// `disclaimerOverride` boolean in the CMS AND filling in `disclaimer`
// with the custom markdown. To update the club-wide text, edit this
// constant once; every event without an active override picks up the
// new wording on the next build.
const DEFAULT_DISCLAIMER = `**Insurance:** From 1st January 2026, participants who are not members of British Orienteering will no longer be covered by British Orienteering's public liability insurance. By entering any event from 1st January 2026, you acknowledge that you are taking part at your own risk. For example, if you were to accidentally injure a member of the public or damage property during the event, you would not be covered. British Orienteering's public liability insurance used to cover non-members at events before this date.`;
const customDisclaimer = (event.data.disclaimer ?? '').trim();
const disclaimerSource =
  event.data.disclaimerOverride && customDisclaimer
    ? customDisclaimer
    : DEFAULT_DISCLAIMER;
marked.setOptions({ gfm: true, breaks: true });
const disclaimerHtml = marked.parse(disclaimerSource);

// Decap CMS sometimes saves image paths with a "public/" prefix (the
// repo path) instead of the public URL ("/assets/uploads/..."). This
// helper strips that prefix and guarantees a leading slash so the
// browser can resolve the URL correctly.
function normaliseImagePath(p) {
  if (!p) return p;
  let out = p.replace(/^public\//, '/');
  if (!out.startsWith('/') && !out.startsWith('http')) out = '/' + out;
  return out;
}
const heroImageSrc = normaliseImagePath(event.data.heroImage);

// ─────── Date formatters
const fmtFullDate = (d: Date) => new Intl.DateTimeFormat('en-GB', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
}).format(d).replace(',', '');

const fmtDay = (d: Date) => new Intl.DateTimeFormat('en-GB', { day: 'numeric' }).format(d);
const fmtMonth = (d: Date) => new Intl.DateTimeFormat('en-GB', { month: 'long' }).format(d);
const fmtYear = (d: Date) => new Intl.DateTimeFormat('en-GB', { year: 'numeric' }).format(d);

const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

// ─────── Location helpers, prefers the CMS map-pin (Decap "map"
// widget GeoJSON output) over the manual lat/lng object.
import { resolveCoords } from '../../lib/coords';
const coords = resolveCoords(event.data);
const mapsLink = coords
  ? `https://www.google.com/maps/place/${coords.lat},${coords.lng}/@${coords.lat},${coords.lng},14z`
  : null;
const osmLink = coords
  ? `https://www.openstreetmap.org/?mlat=${coords.lat}&mlon=${coords.lng}&zoom=14`
  : null;
const streetmapLink = coords
  ? `https://www.streetmap.co.uk/loc/${coords.lat},${coords.lng}`
  : null;
const bingLink = coords
  ? `https://www.bing.com/maps/?v=2&lvl=14&style=s&cp=${coords.lat}~${coords.lng}&q=${coords.lat},${coords.lng}`
  : null;

// ─────── File-type label / icon
const fileTypeLabel = (t: string) => {
  switch (t) {
    case 'pdf': return 'PDF';
    case 'xlsx': return 'Excel';
    case 'csv': return 'CSV';
    case 'html': default: return 'View online';
  }
};

// ─────── Schema.org Event JSON-LD
// Google reads this and surfaces the event in event-rich-result cards.
// https://developers.google.com/search/docs/appearance/structured-data/event
const siteUrl = Astro.site ?? new URL("https://pfo.org.uk");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();

// Combine event date with start time, if provided. Otherwise use date at 00:00.
function combineDateAndTime(date: Date, displayTime?: string): string {
  if (!displayTime) return date.toISOString();
  // Parse "7:00pm" / "10:30am" into 24h and apply to the date
  const m = displayTime.trim().toLowerCase().match(/^(\d{1,2})(?::(\d{2}))?\s*(am|pm)?$/);
  if (!m) return date.toISOString();
  let hours = parseInt(m[1], 10);
  const mins = m[2] ? parseInt(m[2], 10) : 0;
  const meridiem = m[3];
  if (meridiem === 'pm' && hours < 12) hours += 12;
  if (meridiem === 'am' && hours === 12) hours = 0;
  const d = new Date(date);
  d.setHours(hours, mins, 0, 0);
  return d.toISOString();
}

const startIso = combineDateAndTime(event.data.date, event.data.startTime);

const eventJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  name: event.data.title,
  description: event.data.description ?? event.data.summary,
  startDate: startIso,
  eventStatus: event.data.cancelled
    ? "https://schema.org/EventCancelled"
    : "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  url: canonical,
  organizer: {
    "@type": "SportsOrganization",
    name: "Pendle Forest Orienteers",
    url: siteUrl.toString(),
  },
  sport: "Orienteering",
  location: {
    "@type": "Place",
    name: event.data.venue ?? event.data.location,
    address: {
      "@type": "PostalAddress",
      addressLocality: event.data.location,
      ...(event.data.postcode ? { postalCode: event.data.postcode } : {}),
      addressRegion: "Lancashire",
      addressCountry: "GB",
    },
    ...(coords ? {
      geo: {
        "@type": "GeoCoordinates",
        latitude: coords.lat,
        longitude: coords.lng,
      }
    } : {}),
  },
};

if (event.data.entryFee && event.data.siEntriesUrl) {
  eventJsonLd.offers = {
    "@type": "Offer",
    price: event.data.entryFee,
    priceCurrency: "GBP",
    availability: "https://schema.org/InStock",
    url: event.data.siEntriesUrl,
    validThrough: event.data.entryCloseDate.toISOString(),
  };
}
---
<Layout
  title={`${event.data.title}, ${fmtMonth(event.data.date)} ${fmtYear(event.data.date)}, PFO`}
  description={event.data.description ?? event.data.summary}
  ogType="article"
  publishedTime={event.data.date.toISOString()}
>

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home",   item: siteUrl.toString() },
      { "@type": "ListItem", position: 2, name: "Events", item: new URL("/events", siteUrl).toString() },
      { "@type": "ListItem", position: 3, name: event.data.title, item: canonical },
    ],
  })}></script>
  {coords && (
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
  )}
</Fragment>

<main id="main">

  <!-- ─────────────────────────── Optional hero photo banner -->
  {event.data.heroImage && (
    <div class="ev-hero-photo">
      <img src={heroImageSrc} alt={event.data.heroImageAlt ?? ""} loading="eager">
    </div>
  )}

  <!-- ─────────────────────────── Event hero -->
  <section class="ev-hero">
    <div class="ev-hero-wrap">
      <a class="back-link" href="/events">← All events</a>

      <div class="ev-hero-grid">
        <div class="ev-hero-left">
          <p class="eyebrow">
            {event.data.format}
            {event.data.location && <><span aria-hidden="true"> · </span>{event.data.location}</>}
            <span aria-hidden="true"> · </span>{capitalize(event.data.level)} level
          </p>
          <h1>{event.data.title}</h1>
          {event.data.cancelled && (
            <p class="cancelled-banner">Cancelled</p>
          )}
          {event.data.description && <p class="ev-hero-lede">{event.data.description}</p>}

          <dl class="ev-key-facts">
            <div>
              <dt>Date</dt>
              <dd>{fmtFullDate(event.data.date)}</dd>
            </div>
            {event.data.startTime && (
              <div>
                <dt>Start</dt>
                <dd>{event.data.startTime}</dd>
              </div>
            )}
            {event.data.entryFee && (
              <div>
                <dt>Entry</dt>
                <dd>{event.data.entryFee}</dd>
              </div>
            )}
            {event.data.capacity && (
              <div>
                <dt>Capacity</dt>
                <dd>{event.data.capacity} entrants</dd>
              </div>
            )}
            {event.data.dogsAllowed && (
              <div>
                <dt>Dogs</dt>
                <dd>
                  {event.data.dogsAllowed === 'yes' && 'Welcome'}
                  {event.data.dogsAllowed === 'on-lead' && 'On lead only'}
                  {event.data.dogsAllowed === 'no' && 'Not permitted'}
                  {event.data.dogsAllowed === 'not-recommended' && 'Not recommended'}
                </dd>
              </div>
            )}
            {event.data.bofEventNumber && (
              <div>
                <dt>BOF event no.</dt>
                <dd class="mono">
                  {/^\d+$/.test(String(event.data.bofEventNumber)) ? (
                    <a
                      href={`https://www.britishorienteering.org.uk/event?event=${event.data.bofEventNumber}&bpage=0`}
                      rel="noopener"
                      target="_blank"
                      class="bof-link"
                    >{event.data.bofEventNumber} ↗</a>
                  ) : (
                    <span>{event.data.bofEventNumber}</span>
                  )}
                </dd>
              </div>
            )}
            {event.data.venue && (
              <div class="full">
                <dt>Venue</dt>
                <dd>{event.data.venue}{event.data.postcode && <>, <span class="mono">{event.data.postcode}</span></>}</dd>
              </div>
            )}
          </dl>
        </div>

        <aside class="ev-hero-right">
          {isOpenForEntry && event.data.siEntriesUrl && !event.data.cancelled && (
            <div class="cta-card primary">
              <p class="cta-label">Online entry</p>
              <p class="cta-detail">Open until {fmtFullDate(event.data.entryCloseDate)}</p>
              <a class="btn btn-primary btn-full" href={event.data.siEntriesUrl} rel="noopener">
                Enter via SI Entries <span class="arrow">→</span>
              </a>
            </div>
          )}

          {isOpenForEntry && !event.data.siEntriesUrl && !event.data.cancelled && (
            <div class="cta-card neutral">
              <p class="cta-label">Online entry</p>
              <p class="cta-detail">Entry details to follow</p>
            </div>
          )}

          {!isOpenForEntry && isUpcoming && !event.data.cancelled && (
            <div class="cta-card neutral">
              <p class="cta-label">Online entry</p>
              <p class="cta-detail">Entries closed</p>
            </div>
          )}

          {!isUpcoming && !hasResults && (
            <div class="cta-card neutral">
              <p class="cta-label">Event finished</p>
              <p class="cta-detail">Results to follow</p>
            </div>
          )}

          {event.data.routeGadgetUrl && (
            <a class="link-row" href={event.data.routeGadgetUrl} rel="noopener">
              <span>View on RouteGadget</span>
              <span aria-hidden="true">→</span>
            </a>
          )}

          <button class="link-row print-btn" type="button" onclick="window.print()">
            <span>Print this page</span>
            <span aria-hidden="true">⎙</span>
          </button>
        </aside>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── Results files (shown FIRST so visitors landing
       the morning after an event get straight to their splits, no scrolling).
       The Report button (if present) sits alongside the results files so it's
       discoverable in the same place. -->
  {(hasResults || hasReport) && (
    <section id="results" class="ev-results">
      <div class="ev-results-wrap">
        <h2>Results{hasReport && !hasResults ? ' & report' : ''}</h2>
        <ul class="results-list">
          {visibleResults.map(file => (
            <li>
              <a href={file.url} rel="noopener">
                <span class="result-icon" data-type={file.type}>{fileTypeLabel(file.type)}</span>
                <span class="result-label">{file.label}</span>
                <span class="result-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
          {hasReport && (
            <li>
              <a href={`/events/${event.id}/report`}>
                <span class="result-icon" data-type="report">Report</span>
                <span class="result-label">Event report</span>
                <span class="result-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          )}
        </ul>
      </div>
    </section>
  )}

  <!-- ─────────────────────────── Body content -->
  <section class="ev-body">
    <div class="ev-body-wrap">
      <article class="ev-prose">
        <Content />
        {event.data.attachments && event.data.attachments.length > 0 && (
          <Attachments attachments={event.data.attachments} />
        )}
        {event.data.gallery && event.data.gallery.length > 0 && (
          <section class="ev-gallery" aria-label="Event photos">
            <h2>Photos from the event</h2>
            <div class="ev-gallery-carousel" data-count={event.data.gallery.length}>
              <button type="button" class="ev-gallery-nav ev-gallery-nav-prev" aria-label="Previous photos">‹</button>
              <div class="ev-gallery-viewport">
                <ul class="ev-gallery-track">
                  {event.data.gallery.map(image => (
                    <li class="ev-gallery-slide">
                      <a href={image.src} class="ev-gallery-link" data-caption={image.caption ?? ""}>
                        <img src={image.src} alt={image.alt ?? ""} loading="lazy">
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <button type="button" class="ev-gallery-nav ev-gallery-nav-next" aria-label="Next photos">›</button>
            </div>
          </section>
        )}
        <!-- Disclaimer (yellow box). Lives at the bottom of the body
             article so it sits visually below the body content on every
             viewport — on mobile it falls between the body text and the
             map (which is in the aside, stacked below). -->
        <div class="ev-disclaimer-box" set:html={disclaimerHtml}></div>
      </article>

      <aside class="ev-meta">
        <div class="meta-block">
          <p class="meta-label">Location</p>
          <p class="meta-place">{event.data.location}</p>
          {coords && (
            <div
              id="event-venue-map"
              class="event-venue-map"
              data-lat={coords.lat}
              data-lng={coords.lng}
              data-title={event.data.venue ?? event.data.location}
              aria-label={`Map of ${event.data.venue ?? event.data.location}`}
            ></div>
          )}
          {coords && (
            <p class="meta-coord mono">{coords.lat.toFixed(5)}, {coords.lng.toFixed(5)}</p>
          )}
          {event.data.gridRef && (
            <p class="meta-postcode mono">OS {event.data.gridRef}</p>
          )}
          {event.data.postcode && (
            <p class="meta-postcode mono">{event.data.postcode}</p>
          )}
          {event.data.what3words && (
            <p class="meta-postcode">
              <a
                class="w3w"
                href={`https://what3words.com/${event.data.what3words}`}
                rel="noopener"
                target="_blank"
              >
                ///<span class="mono">{event.data.what3words}</span>
              </a>
            </p>
          )}
          {coords && (
            <ul class="map-links">
              <li><a href={mapsLink} rel="noopener" target="_blank">Google Maps →</a></li>
              <li><a href={osmLink} rel="noopener" target="_blank">OpenStreetMap →</a></li>
              <li><a href={streetmapLink} rel="noopener" target="_blank">Streetmap (OS 50k) →</a></li>
              <li><a href={bingLink} rel="noopener" target="_blank">Bing Maps (OS) →</a></li>
            </ul>
          )}
          {!coords && (
            <p class="meta-note">Coordinates and map links will appear here once the committee adds them.</p>
          )}
        </div>

        {(event.data.planner || event.data.controller || event.data.seriesOrganiser) && (
          <div class="meta-block">
            <p class="meta-label">Officials</p>
            <dl class="officials">
              {event.data.planner && (
                <>
                  <dt>Planner</dt>
                  <dd>{event.data.planner}</dd>
                </>
              )}
              {event.data.controller && (
                <>
                  <dt>Controller</dt>
                  <dd>{event.data.controller}</dd>
                </>
              )}
              {event.data.seriesOrganiser && (
                <>
                  <dt>Series organiser</dt>
                  <dd>{event.data.seriesOrganiser}</dd>
                </>
              )}
            </dl>
          </div>
        )}

        {event.data.dogNotes && (
          <div class="meta-block">
            <p class="meta-label">Dogs</p>
            <p class="meta-note">{event.data.dogNotes}</p>
          </div>
        )}

        <div class="meta-block">
          <p class="meta-label">Event level</p>
          <p>
            <span class={`level level-${event.data.level}`}>{capitalize(event.data.level)}</span>
          </p>
          <p class="meta-note">
            {event.data.level === 'local' && 'Low-key, ideal for newcomers.'}
            {event.data.level === 'regional' && 'Attracts orienteers from across the North West.'}
            {event.data.level === 'national' && 'High-quality competition drawing competitors from across the UK.'}
            {event.data.level === 'major' && 'A major event such as a British Championships or JK round.'}
          </p>
        </div>
      </aside>
    </div>
  </section>

  <!-- ─────────────────────────── Lightbox overlay (for gallery photos) -->
  {event.data.gallery && event.data.gallery.length > 0 && (
    <div id="ev-gallery-lightbox" class="ev-gallery-lightbox" hidden>
      <button type="button" class="ev-gallery-lightbox-close" aria-label="Close">×</button>
      <button type="button" class="ev-gallery-lightbox-prev" aria-label="Previous">‹</button>
      <img class="ev-gallery-lightbox-img" src="" alt="">
      <p class="ev-gallery-lightbox-caption"></p>
      <button type="button" class="ev-gallery-lightbox-next" aria-label="Next">›</button>
    </div>
  )}

</main>

{coords && (
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
          crossorigin=""></script>
  <script is:inline>
    // Render the venue map after Leaflet has loaded.
    window.addEventListener('DOMContentLoaded', function () {
      var el = document.getElementById('event-venue-map');
      if (!el || typeof window.L === 'undefined') return;
      var lat = parseFloat(el.dataset.lat);
      var lng = parseFloat(el.dataset.lng);
      var title = el.dataset.title || 'Event venue';
      if (Number.isNaN(lat) || Number.isNaN(lng)) return;

      var map = window.L.map(el, {
        center: [lat, lng],
        zoom: 14,
        scrollWheelZoom: false,
      });
      window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);
      window.L.marker([lat, lng]).addTo(map).bindPopup('<strong>' + title + '</strong>').openPopup();

      // Allow scroll-wheel zoom only after the user clicks/touches the map,
      // so they don't get hijacked while scrolling the page.
      el.addEventListener('click', function () { map.scrollWheelZoom.enable(); });
    });
  </script>
)}

<script>
  // Paginated carousel + lightbox for the event photo gallery.
  (function () {
    const carousel = document.querySelector('.ev-gallery-carousel');
    if (!carousel) return;
    const track = carousel.querySelector('.ev-gallery-track');
    const slides = track.querySelectorAll('.ev-gallery-slide');
    const total = slides.length;
    if (total === 0) return;
    const prev = carousel.querySelector('.ev-gallery-nav-prev');
    const next = carousel.querySelector('.ev-gallery-nav-next');
    let pos = 0;

    // ─── Lightbox setup ──────────────────────────────────────────────
    const links = Array.from(carousel.querySelectorAll('.ev-gallery-link'));
    const lb = document.getElementById('ev-gallery-lightbox');
    if (lb) {
      const lbImg   = lb.querySelector('.ev-gallery-lightbox-img');
      const lbCap   = lb.querySelector('.ev-gallery-lightbox-caption');
      const lbClose = lb.querySelector('.ev-gallery-lightbox-close');
      const lbPrev  = lb.querySelector('.ev-gallery-lightbox-prev');
      const lbNext  = lb.querySelector('.ev-gallery-lightbox-next');
      let lbIdx = 0;
      function lbShow(i) {
        lbIdx = (i + links.length) % links.length;
        const a = links[lbIdx];
        lbImg.src = a.getAttribute('href');
        lbImg.alt = a.querySelector('img').alt || '';
        const c = a.getAttribute('data-caption') || '';
        lbCap.textContent = c;
        lbCap.style.display = c ? 'block' : 'none';
        lb.hidden = false;
        document.body.style.overflow = 'hidden';
      }
      function lbHide() {
        lb.hidden = true;
        document.body.style.overflow = '';
      }
      links.forEach((a, i) => {
        a.addEventListener('click', (e) => { e.preventDefault(); lbShow(i); });
      });
      lbClose.addEventListener('click', lbHide);
      lbPrev.addEventListener('click', () => lbShow(lbIdx - 1));
      lbNext.addEventListener('click', () => lbShow(lbIdx + 1));
      lb.addEventListener('click', (e) => { if (e.target === lb) lbHide(); });
      document.addEventListener('keydown', (e) => {
        if (lb.hidden) return;
        if (e.key === 'Escape') lbHide();
        else if (e.key === 'ArrowLeft')  lbShow(lbIdx - 1);
        else if (e.key === 'ArrowRight') lbShow(lbIdx + 1);
      });
    }
    // Mobile shows 1 photo, desktop shows 3. Limit pos to never overshoot
    // into trailing empty slots when the photo count isn't a multiple of 3.
    function visibleCount() {
      return window.matchMedia('(max-width: 720px)').matches ? 1 : 3;
    }
    function maxPos() {
      return Math.max(0, total - visibleCount());
    }
    function update() {
      const slot = slides[0].getBoundingClientRect().width + 14;
      track.style.transform = `translateX(${-pos * slot}px)`;
    }
    function step(dir) {
      const m = maxPos();
      pos += dir;
      if (pos > m) pos = 0;
      if (pos < 0) pos = m;
      update();
    }
    if (prev) prev.addEventListener('click', () => step(-1));
    if (next) next.addEventListener('click', () => step(1));
    window.addEventListener('resize', () => {
      // Recompute slot width and clamp pos if visibleCount changed
      if (pos > maxPos()) pos = maxPos();
      update();
    });

    // Swipe support on touch devices
    let touchStart = 0;
    track.addEventListener('touchstart', (e) => { touchStart = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStart;
      if (Math.abs(dx) > 40) step(dx < 0 ? 1 : -1);
    });
  })();
</script>

</Layout>

