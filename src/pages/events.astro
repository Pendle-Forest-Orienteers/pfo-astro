---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import EventCalendar from '../components/EventCalendar.astro';
import { getCollection } from 'astro:content';
import { resolveCoords } from '../lib/coords';
import { neighbouringClubs } from '../data/neighbouring-clubs';
import { isEventUpcoming, isEventPast } from '../lib/event-state';

// ─────── Data: split events into upcoming and past
// Events stay under "Upcoming" until the day AFTER the event date — so a
// 16 May event still shows as upcoming on 16 May and only moves to results
// on 17 May. This is independent of entryCloseDate (which only governs
// whether the Enter CTA is shown on the detail page).
const startOfToday = new Date();
startOfToday.setHours(0, 0, 0, 0);
const now = new Date(); // still used by EventCalendar etc.
const allEvents = await getCollection('events');

// Neighbouring-club events are fetched client-side at request time
// (via /api/neighbour-events Netlify Function) because BOF blocks the
// Netlify build server's IPs. Until that promise resolves, the page
// renders the fallback club-list below; the script swaps it out for a
// populated table on success.

const upcoming = allEvents
  .filter(e => isEventUpcoming(e.data, now) && !e.data.cancelled && !e.data.hidden)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const past = allEvents
  .filter(e => isEventPast(e.data, now) && !e.data.hidden)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group past events by year
const pastByYear = past.reduce((acc, event) => {
  const year = event.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(event);
  return acc;
}, {} as Record<number, typeof past>);
const pastYears = Object.keys(pastByYear).map(Number).sort((a, b) => b - a);

// ─────── Date formatters
const fmtRowDate = (d: Date) => new Intl.DateTimeFormat('en-GB', {
  weekday: 'short', day: 'numeric', month: 'short'
}).format(d).replace(',', '');

const fmtDay = (d: Date) => new Intl.DateTimeFormat('en-GB', { day: 'numeric' }).format(d);
const fmtMonth = (d: Date) => new Intl.DateTimeFormat('en-GB', { month: 'short' }).format(d);
const fmtWeekday = (d: Date) => new Intl.DateTimeFormat('en-GB', { weekday: 'short' }).format(d);
const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
---
<Layout
  title="Events, Pendle Forest Orienteers"
  description="Upcoming fixtures and past results from Pendle Forest Orienteers, orienteering events across East Lancashire."
>

<main id="main">

  <!-- ─────────────────────────── Page hero -->
  <PageHero
    page="events"
    eyebrow="Events"
    heading="Orienteering events in East Lancashire."
    lede="PFO runs around 12–15 events a year, local midweek street events, weekend regionals on the fells, and the headline Brun Valley fixture in May. Online entry via SI Entries; turn-up-on-the-day welcome where space allows."
  >
    <nav class="anchor-nav rise d-4" aria-label="Skip to section">
      <a href="#calendar">Calendar</a>
      <span aria-hidden="true">·</span>
      <a href="#upcoming">Upcoming ({upcoming.length})</a>
      <span aria-hidden="true">·</span>
      <a href="#past">Past results ({past.length})</a>
      <span aria-hidden="true">·</span>
      <a href="#neighbours">Neighbouring clubs</a>
      <span aria-hidden="true">·</span>
      <a href="/events.ics">📅 Subscribe to calendar</a>
      <span aria-hidden="true">·</span>
      <a href="https://www.britishorienteering.org.uk/event" rel="noopener">BOF event listings →</a>
      <span aria-hidden="true">·</span>
      <a href="https://www.pfo.routegadget.co.uk/rg2/" rel="noopener">RouteGadget →</a>
    </nav>
  </PageHero>

  <!-- ─────────────────────────── Map + Calendar (side-by-side at the top)
       Map takes the bulk of the width, calendar sits in a narrower column
       on the right. Stacks on phones. -->
  {(upcoming.some(e => resolveCoords(e.data)) || upcoming.length > 0) && (
    <section id="map" class="map-and-calendar" aria-label="Events overview">
      <div class="mc-grid">
        {upcoming.some(e => resolveCoords(e.data)) && (
          <div class="mc-map">
            <div id="events-map"
                 class="events-map"
                 data-events={JSON.stringify(
                   upcoming
                     .map(e => ({ event: e, c: resolveCoords(e.data) }))
                     .filter(({ c }) => !!c)
                     .map(({ event: e, c }) => ({
                       lat: c!.lat,
                       lng: c!.lng,
                       title: e.data.title,
                       url: `/events/${e.id}`,
                       date: new Intl.DateTimeFormat('en-GB',
                         { weekday: 'short', day: 'numeric', month: 'short' })
                         .format(e.data.date),
                       format: e.data.format,
                       location: e.data.location,
                     }))
                 )}>
            </div>
            <noscript>
              <p class="empty">The map view needs JavaScript to render. The list below works without it.</p>
            </noscript>
          </div>
        )}

        {upcoming.length > 0 && (
          <div class="mc-calendar" id="calendar">
            <div class="mc-calendar-head">
              <p class="eyebrow">At a glance</p>
              <span class="mc-calendar-sub">Next 2 months</span>
            </div>
            <EventCalendar
              events={upcoming.map(e => ({
                id: e.id,
                title: e.data.title,
                date: e.data.date,
                format: e.data.format,
                location: e.data.location,
              }))}
              monthsAhead={2}
            />
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ─────────────────────────── Upcoming events -->
  <section id="upcoming" class="event-section">
    <div class="sec-head">
      <p class="eyebrow">Upcoming</p>
      <span class="sec-count">{upcoming.length} fixture{upcoming.length === 1 ? '' : 's'}</span>
    </div>
    {upcoming.length === 0 ? (
      <p class="empty">No upcoming events scheduled. Check back soon, or follow us on Facebook for early notice.</p>
    ) : (
      <ul class="event-list">
        {upcoming.map(event => (
          <li>
            <a class="ev-row" href={`/events/${event.id}`}>
              <time class="ev-row-date" datetime={event.data.date.toISOString()}>
                <span class="ev-row-day">{fmtDay(event.data.date)}</span>
                <span class="ev-row-month">{fmtMonth(event.data.date)}</span>
                <span class="ev-row-weekday">{fmtWeekday(event.data.date)}</span>
              </time>
              <div class="ev-row-body">
                <h3>{event.data.title}</h3>
                <p class="ev-row-meta">
                  <span>{event.data.format}</span>
                  {event.data.location && <><span aria-hidden="true">·</span><span>{event.data.location}</span></>}
                  {event.data.startTime && <><span aria-hidden="true">·</span><span>{event.data.startTime}</span></>}
                  {event.data.entryFee && <><span aria-hidden="true">·</span><span>{event.data.entryFee.split(/[(.]/)[0].trim()}</span></>}
                </p>
              </div>
              <span class={`level level-${event.data.level}`}>{capitalize(event.data.level)}</span>
              <span class="ev-row-action" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}

    <!-- CTA: jump down to the neighbouring-clubs table. Bottom-right of
         the upcoming list. The count badge is filled in client-side once
         the /api/neighbour-events function returns. -->
    <div class="upcoming-cta">
      <a class="neighbour-cta" href="#neighbours">
        <span class="neighbour-cta-icon" aria-hidden="true">↓</span>
        <span class="neighbour-cta-text">Events from neighbouring clubs</span>
        <span class="neighbour-cta-count" data-neighbour-count hidden></span>
      </a>
    </div>
  </section>

  <!-- ─────────────────────────── Past events / results -->
  <section id="past" class="event-section past">
    <div class="sec-head">
      <p class="eyebrow">Past results</p>
      <span class="sec-count">{past.length} event{past.length === 1 ? '' : 's'}</span>
    </div>
    {past.length === 0 ? (
      <p class="empty">No past events to show yet.</p>
    ) : (
      pastYears.map(year => (
        <div class="year-group">
          <h2 class="year-heading">{year}</h2>
          <ul class="event-list">
            {pastByYear[year].map(event => {
              // Filter out any results entries marked hidden in the CMS
              const visibleResults = (event.data.results ?? []).filter(r => !r.hidden);
              const hasResults = visibleResults.length > 0;
              return (
                <li class="past-row-li">
                  <div class="past-row-main">
                    <a class="ev-row past-row" href={`/events/${event.id}`}>
                      <time class="ev-row-date" datetime={event.data.date.toISOString()}>
                        <span class="ev-row-day">{fmtDay(event.data.date)}</span>
                        <span class="ev-row-month">{fmtMonth(event.data.date)}</span>
                        <span class="ev-row-weekday">{fmtWeekday(event.data.date)}</span>
                      </time>
                      <div class="ev-row-body">
                        <h3>{event.data.title}</h3>
                        <p class="ev-row-meta">
                          <span>{event.data.format}</span>
                          {event.data.location && <><span aria-hidden="true">·</span><span>{event.data.location}</span></>}
                        </p>
                      </div>
                      <span class={`level level-${event.data.level}`}>{capitalize(event.data.level)}</span>
                    </a>
                    {hasResults ? (
                      <a class="results-quick-link"
                         href={`/events/${event.id}#results`}
                         data-results-toggle
                         aria-expanded="false"
                         aria-controls={`results-${event.id}`}
                         aria-label={`${event.data.title}, show all results files`}>
                        <span class="results-quick-tag">Results</span>
                        <span class="results-quick-count">{visibleResults.length}</span>
                        <span class="results-quick-arrow" aria-hidden="true">▾</span>
                      </a>
                    ) : (
                      <span class="results-quick-link results-quick-link--empty" aria-hidden="true">
                        <span class="results-quick-tag results-quick-tag--empty">No results</span>
                      </span>
                    )}
                  </div>
                  {hasResults && (
                    <ul class="past-row-files" id={`results-${event.id}`} hidden>
                      {visibleResults.map(file => (
                        <li>
                          <a href={file.url}
                             rel="noopener"
                             target={file.url.startsWith('http') ? '_blank' : undefined}>
                            <span class="past-row-file-tag" data-type={file.type}>
                              {file.type === 'pdf' ? 'PDF' : file.type === 'xlsx' ? 'Excel' : file.type === 'csv' ? 'CSV' : 'View'}
                            </span>
                            <span class="past-row-file-label">{file.label}</span>
                            <span class="past-row-file-arrow" aria-hidden="true">→</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ))
    )}
  </section>

  <!-- ─────────────────────────── Neighbouring clubs
       Live BOF feed via /api/neighbour-events (Netlify Function).
       Three states, all rendered server-side and toggled by the script
       at the bottom of the page:
         · loading  , shown by default while fetch is in flight
         · table    , populated on success
         · fallback , club-card list, shown if fetch fails or returns 0
       This way the section is always meaningful even with JS off (the
       fallback is the default visible state), and progressively
       enhances when the function returns rows. -->
  <section id="neighbours" class="event-section neighbours" data-neighbour-section>
    <div class="sec-head">
      <p class="eyebrow">Neighbouring clubs</p>
      <span class="sec-count" data-neighbour-count-text>{neighbouringClubs.length} clubs</span>
    </div>

    <p class="neighbours-intro">
      Upcoming events run by orienteering clubs in the wider North-West and
      Yorkshire region. PFO members are welcome to enter, most events accept
      pre-entry through SI Entries or Fabian4. For a national overview see
      <a href="https://www.britishorienteering.org.uk/event" rel="noopener">British Orienteering's full event listing →</a>.
    </p>

    <!-- Loading state (visible by default; script hides it once fetch resolves) -->
    <div class="neighbour-loading" data-neighbour-loading>
      <p class="neighbour-loading-note">
        <span class="loading-dot" aria-hidden="true"></span>
        Loading upcoming events from British Orienteering…
      </p>
    </div>

    <!-- Table, empty until populated by the script -->
    <div class="neighbour-table-wrap" data-neighbour-table hidden>
      <table class="neighbour-table">
        <thead>
          <tr>
            <th scope="col">Date</th>
            <th scope="col">Event</th>
            <th scope="col">Club</th>
            <th scope="col">Near</th>
            <th scope="col">Level</th>
          </tr>
        </thead>
        <tbody data-neighbour-tbody></tbody>
      </table>
    </div>

    <!-- Fallback, shown if fetch fails or returns no events.
         Also the no-JS default. -->
    <div class="neighbour-fallback" data-neighbour-fallback>
      <p class="neighbour-fallback-note">
        Live feed unavailable right now. Check each club's events page directly:
      </p>
      <ul class="neighbour-club-list">
        {neighbouringClubs.map(club => (
          <li>
            <a href={club.eventsUrl} rel="noopener" target="_blank">
              <span class="neighbour-club-abbr">{club.abbr}</span>
              <span class="neighbour-club-name">{club.name}</span>
              <span class="neighbour-club-region">{club.region}</span>
              <span class="neighbour-club-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</main>

</Layout>

<Fragment slot="head">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin="" />
</Fragment>

<script is:inline>
  // Past-event Results toggle: click the Results button to expand an
  // inline list of all result files for that event, instead of having
  // to click through to the event detail page. Falls back to a normal
  // link if JS is off.
  document.addEventListener('DOMContentLoaded', function () {
    var toggles = document.querySelectorAll('[data-results-toggle]');
    Array.prototype.forEach.call(toggles, function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        var expanded = el.getAttribute('aria-expanded') === 'true';
        el.setAttribute('aria-expanded', String(!expanded));
        var panelId = el.getAttribute('aria-controls');
        var panel = panelId ? document.getElementById(panelId) : null;
        if (panel) panel.hidden = expanded;
        var arrow = el.querySelector('.results-quick-arrow');
        if (arrow) arrow.textContent = expanded ? '▾' : '▴'; // ▾ / ▴
      });
    });
  });
</script>

<script is:inline>
  // Neighbouring-clubs hydration. Calls the Netlify Function that
  // proxies BOF, then either fills in the table or leaves the fallback
  // visible. Loading dot stays in either case until the swap happens.
  document.addEventListener('DOMContentLoaded', function () {
    var section  = document.querySelector('[data-neighbour-section]');
    if (!section) return;
    var loading  = section.querySelector('[data-neighbour-loading]');
    var tableWrap= section.querySelector('[data-neighbour-table]');
    var tbody    = section.querySelector('[data-neighbour-tbody]');
    var fallback = section.querySelector('[data-neighbour-fallback]');
    var countText= document.querySelector('[data-neighbour-count-text]');
    var ctaCount = document.querySelector('[data-neighbour-count]');

    fetch('/api/neighbour-events', { credentials: 'omit' })
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function (data) {
        var events = (data && data.events) || [];
        if (loading) loading.hidden = true;
        if (events.length === 0) {
          // Keep fallback visible, nothing came back.
          return;
        }
        // Build table rows
        var rows = events.map(function (e) {
          var d = new Date(e.date);
          var dateStr = d.toLocaleDateString('en-GB', {
            weekday: 'short', day: 'numeric', month: 'short'
          }).replace(',', '');
          var clubLower = (e.club || '').toLowerCase();
          var safe = function (s) {
            return String(s == null ? '' : s)
              .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
          };
          return (
            '<tr class="nb-row nb-row-' + safe(clubLower) + '" data-club="' + safe(clubLower) + '">' +
              '<td class="nb-date"><time datetime="' + safe(e.date) + '">' + safe(dateStr) + '</time></td>' +
              '<td class="nb-title"><a href="' + safe(e.url) + '" rel="noopener" target="_blank">' + safe(e.title) + '</a></td>' +
              '<td class="nb-club"><span class="nb-club-tag nb-club-' + safe(clubLower) + '">' + safe(e.club) + '</span></td>' +
              '<td class="nb-near">' + (e.near ? safe(e.near) : '—') + '</td>' +
              '<td class="nb-level">' + (e.level ? safe(e.level) : '—') + '</td>' +
            '</tr>'
          );
        }).join('');
        if (tbody) tbody.innerHTML = rows;
        if (tableWrap) tableWrap.hidden = false;
        if (fallback) fallback.hidden = true;
        if (countText) countText.textContent = events.length + ' fixture' + (events.length === 1 ? '' : 's');
        if (ctaCount) {
          ctaCount.textContent = String(events.length);
          ctaCount.hidden = false;
        }
      })
      .catch(function () {
        // Leave fallback visible; just hide the loading note.
        if (loading) loading.hidden = true;
      });
  });
</script>

<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
<script is:inline>
  // Render the events map after Leaflet has loaded.
  // Default view: Burnley town centre at zoom 11, covers the PFO
  // catchment (Burnley, Padiham, Pendle, Blackburn, Clitheroe). If
  // upcoming events are spread further, fitBounds extends outward,
  // but never zooms in tighter than Burnley's default, single-event
  // street-level zoom was disorientating.
  window.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('events-map');
    if (!el || typeof window.L === 'undefined') return;
    var events = [];
    try { events = JSON.parse(el.dataset.events || '[]'); } catch (e) {}

    var BURNLEY = [53.789, -2.248];
    var DEFAULT_ZOOM = 11;

    var map = L.map(el, {
      scrollWheelZoom: false,
      minZoom: 7,
    }).setView(BURNLEY, DEFAULT_ZOOM);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 18,
      attribution: '© OpenStreetMap contributors',
    }).addTo(map);

    if (events.length > 0) {
      events.forEach(function (e) {
        var popup =
          '<strong><a href="' + e.url + '">' + e.title + '</a></strong><br>' +
          e.date + ' · ' + e.format +
          (e.location ? ' · ' + e.location : '');
        L.marker([e.lat, e.lng]).addTo(map).bindPopup(popup);
      });

      // If any event sits outside what zoom-11 around Burnley shows
      // naturally, widen the view to include it. maxZoom caps any
      // tightening so we never zoom in past the default.
      var lats = events.map(function (e) { return e.lat; });
      var lngs = events.map(function (e) { return e.lng; });
      lats.push(BURNLEY[0]); lngs.push(BURNLEY[1]);
      var bounds = [
        [Math.min.apply(null, lats), Math.min.apply(null, lngs)],
        [Math.max.apply(null, lats), Math.max.apply(null, lngs)],
      ];
      map.fitBounds(bounds, { padding: [30, 30], maxZoom: DEFAULT_ZOOM });
    }
  });
</script>

<style>
  /* ─────────────────────────── Events overview, map + calendar
     side-by-side. Map fills the left column; calendar tucks into the
     right column at a compact size. Stacks on phones, calendar first
     so people see "next event date" before reaching for the map. */
  .map-and-calendar {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(20px, 3vw, 40px) var(--pad-x) clamp(8px, 2vw, 16px);
  }
  .mc-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 240px;
    gap: clamp(14px, 2vw, 24px);
    align-items: start;
  }
  @media (max-width: 720px) {
    .mc-grid { grid-template-columns: 1fr; }
  }
  .events-map {
    height: clamp(280px, 40vh, 440px);
    width: 100%;
    border: 1px solid var(--rule);
    background: var(--paper-2);
  }

  /* Calendar column header */
  .mc-calendar-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 10px;
    gap: 12px;
  }
  .mc-calendar-head .eyebrow {
    font-family: var(--ff-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-muted);
    margin: 0;
  }
  .mc-calendar-head .eyebrow::before {
    content: "";
    display: inline-block;
    width: 6px; height: 6px;
    background: var(--plum);
    margin-right: 8px;
    transform: translateY(-1px);
  }
  .mc-calendar-sub {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  /* Compact the EventCalendar component when it lives in the side column.
     The component's own styles use `.event-calendar`, overriding here to
     remove its outer padding (we're already inside a padded section) and
     stack the months vertically rather than side-by-side. */
  .mc-calendar :global(.event-calendar) {
    padding: 0;
    max-width: none;
  }
  .mc-calendar :global(.event-calendar-key) { display: none; }
  .mc-calendar :global(.event-calendar-grid) {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .mc-calendar :global(.cal-month) { padding: 12px 12px 10px; }
  .mc-calendar :global(.cal-day) { font-size: 11px; }
  .events-map :global(a) { color: var(--navy); }
  .events-map :global(.leaflet-popup-content) {
    font-family: var(--ff-body);
    font-size: 14px;
    line-height: 1.4;
  }
  .events-map :global(.leaflet-popup-content strong a) {
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-underline-offset: 2px;
  }

  /* ─────────────────────────── Page hero (smaller than homepage hero) */
  .page-hero {
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    padding: clamp(40px, 5vw, 80px) var(--pad-x) clamp(36px, 4vw, 60px);
  }
  .page-hero-wrap {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .page-hero .eyebrow {
    color: var(--gold-muted);
    margin-bottom: 18px;
  }
  .page-hero .eyebrow::before { background: var(--plum); }
  .page-hero h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    margin: 0 0 20px 0;
    color: var(--ink);
    max-width: 22ch;
  }
  .page-lede {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
